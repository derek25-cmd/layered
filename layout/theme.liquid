<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ page_title }} — {{ shop.name }}</title>
    <meta name="description" content="{{ page_description | escape }}" />

    {{ content_for_header }}

    <link rel="icon" type="image/x-icon" href="{{ 'favicon.ico' | asset_url }}" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    {{ 'layered-app.css' | asset_url | stylesheet_tag }}

    {%- comment -%}
      is_native_page: true on any template where the React SPA must NOT mount.
      ─────────────────────────────────────────────────────────────────────────
      IMPORTANT: Shopify's template.name strips the directory component, so
      template.name for templates/customers/login.liquid is "login" — NOT
      "customers/login".  Use template.directory == 'customers' instead,
      which reliably returns "customers" for every file in that folder.
    {%- endcomment -%}
    {%- assign is_native_page = false -%}
    {%- if template.directory == 'customers'
        or template.name == 'collection'
        or template.name == 'product'
        or template.name == 'search'
        or template.name == 'cart'
        or template.name == 'gift_card'
        or template.name == 'password'
        or template.name == 'page' -%}
      {%- assign is_native_page = true -%}
    {%- endif -%}

    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }

      {% unless is_native_page %}
      #root {
        min-height: 100vh;
        overflow-x: hidden;
      }
      .shopify-section-group-header-group,
      .shopify-section-group-footer-group {
        display: none !important;
      }
      {% endunless %}

      img   { max-width: 100%; height: auto; }
      *     { box-sizing: border-box; }
      table { width: 100%; display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }

      {% if is_native_page %}
      body { background: #fff; color: #111; }
      a    { color: inherit; text-decoration: none; }
      {% endif %}
    </style>
  </head>

  <body>
    <script type="application/json" id="shopify-context-data">
      {
        "shopDomain":    {{ shop.permanent_domain | json }},
        "shopName":      {{ shop.name | json }},
        "currency":      {{ shop.currency | json }},
        "locale":        {{ request.locale.iso_code | json }},
        "customerId":    {{ customer.id | json | default: "null" }},
        "customerEmail": {{ customer.email | json | default: "null" }},
        "customerName":  {{ customer.name | json | default: "null" }},
        "cartToken":     {{ cart.token | json | default: "null" }},
        "cartItemCount": {{ cart.item_count | json }},
        "isLoggedIn":    {% if customer %}true{% else %}false{% endif %},
        "template":      {{ template.name | json }}
      }
    </script>
    <script src="{{ 'shopify-context.js' | asset_url }}" defer></script>

    {% unless is_native_page %}
      <div id="root"></div>
      <script type="module" src="{{ 'layered-app.js' | asset_url }}"></script>
    {% endunless %}

    <script>
      // Global state for Virtual Try-On image tracking (Shared between Liquid and React)
      window.currentVtoImage = '';
      
      // Listen for the custom variant:change event dispatched by product-vto.js
      document.addEventListener('variant:change', function(e) {
        if (e.detail && e.detail.variant) {
          window.currentVtoImage = e.detail.variant.image || e.detail.variant.featured_image;
        }
      });
    </script>

    {{ content_for_layout }}
  </body>
</html>
