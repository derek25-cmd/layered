<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ page_title }} — {{ shop.name }}</title>
    <meta name="description" content="{{ page_description | escape }}" />

    {%- comment -%} Shopify required tags {%- endcomment -%}
    {{ content_for_header }}

    {%- comment -%} Favicon {%- endcomment -%}
    <link rel="icon" type="image/x-icon" href="{{ 'favicon.ico' | asset_url }}" />

    {%- comment -%} Google Fonts used by Layered {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    {%- comment -%} Layered app CSS — loaded on all pages for consistent typography and utilities {%- endcomment -%}
    {{ 'layered-app.css' | asset_url | stylesheet_tag }}

    {%- comment -%}
      Determine whether this page is a Shopify-native template that manages
      its own full layout (customer auth, collection, product, search).
      On these pages we suppress the React SPA so it cannot cover the
      Shopify-rendered content or intercept auth callbacks.
    {%- endcomment -%}
    {%- assign is_native_page = false -%}
    {%- if template.name contains 'customers/'
        or template.name == 'collection'
        or template.name == 'product'
        or template.name == 'search'
        or template.name == 'cart'
        or template.name == 'gift_card'
        or template.name == 'password' -%}
      {%- assign is_native_page = true -%}
    {%- endif -%}

    <style>
      body {
        margin: 0;
        padding: 0;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }
      {% unless is_native_page %}
      #root {
        min-height: 100vh;
        overflow-x: hidden;
      }
      /* Hide Shopify's default header/footer — the React SPA has its own */
      .shopify-section-group-header-group,
      .shopify-section-group-footer-group {
        display: none !important;
      }
      {% endunless %}
      img  { max-width: 100%; height: auto; }
      *    { box-sizing: border-box; }
      table {
        width: 100%;
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      {% if is_native_page %}
      /* ── Native-page styles ───────────────────────────────────────────────
         Clean, minimal chrome for Shopify-rendered pages (login, account,
         collections, products, search). No React navbar/footer needed here
         because content_for_layout provides the full page content.
      */
      body { background: #fff; color: #111; }
      a    { color: inherit; }
      {% endif %}
    </style>
  </head>

  <body>
    {%- comment -%}
      Inject Shopify context so both the React SPA and native-page scripts
      can read shop/customer state without extra API calls.
    {%- endcomment -%}
    <script>
      window.__SHOPIFY_CONTEXT__ = {
        shopDomain:    {{ shop.permanent_domain | json }},
        shopName:      {{ shop.name | json }},
        currency:      {{ shop.currency | json }},
        locale:        {{ request.locale.iso_code | json }},
        customerId:    {{ customer.id | json | default: 'null' }},
        customerEmail: {{ customer.email | json | default: 'null' }},
        customerName:  {{ customer.name | json | default: 'null' }},
        cartToken:     {{ cart.token | json | default: 'null' }},
        cartItemCount: {{ cart.item_count | json }},
        isLoggedIn:    {% if customer %}true{% else %}false{% endif %},
        template:      {{ template.name | json }}
      };
    </script>

    {% unless is_native_page %}
      {%- comment -%}
        React SPA root — only mounted on SPA-managed routes (home, /shop,
        /outfits, /auth/*, /account, /ai-assistant, etc.).
        Customer pages, collection pages, product pages, and search use
        Shopify native templates and must NOT have the SPA mounted, otherwise
        React Router's catch-all renders a 404 that covers the template content
        and blocks OAuth callbacks (e.g. Oxi Social Login Google redirect).
      {%- endcomment -%}
      <div id="root"></div>
      <script type="module" src="{{ 'layered-app.js' | asset_url }}"></script>
    {% endunless %}

    {{ content_for_layout }}
  </body>
</html>
