<div class="auth-page">

  <div class="auth-card">

    <div class="auth-header">
      <h1 class="auth-title">Sign in</h1>
      <p class="auth-subtitle">Welcome back to {{ shop.name }}</p>
    </div>

    {%- comment -%}
      "Continue with Google" — links to Shopify's native login URL.
      Shopify's new customer accounts system handles Google OAuth
      internally once the customer lands on that page.
      No third-party app or direct OAuth endpoint is used here.
    {%- endcomment -%}
    <a href="{{ routes.account_login_url }}?return_to={{ routes.account_url }}" class="google-btn" aria-label="Continue with Google">
      <svg class="google-btn__icon" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908C16.658 14.013 17.64 11.706 17.64 9.2z" fill="#4285F4"/>
        <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/>
        <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
        <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
      </svg>
      <span>Continue with Google</span>
    </a>

    <div class="auth-divider">
      <span>or sign in with email</span>
    </div>

    {% form 'customer_login' %}
      {{ form.errors | default_errors }}

      <div class="field">
        <label for="CustomerEmail">Email address</label>
        <input
          type="email"
          name="customer[email]"
          id="CustomerEmail"
          autocomplete="email"
          placeholder="you@example.com"
          required
        >
      </div>

      <div class="field">
        <label for="CustomerPassword">Password</label>
        <input
          type="password"
          name="customer[password]"
          id="CustomerPassword"
          autocomplete="current-password"
          placeholder="Password"
          required
        >
      </div>

      <div class="auth-forgot">
        <a href="{{ routes.account_recover_url }}">Forgot password?</a>
      </div>

      <button type="submit" class="btn-primary">Sign in</button>

      <p class="auth-switch">
        Don't have an account?
        <a href="{{ routes.account_register_url }}">Create one</a>
      </p>

    {% endform %}

  </div>

</div>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background: #f9f9f9;
  }

  .auth-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 24px rgba(0,0,0,.08);
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 420px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .auth-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 .375rem;
    color: #111;
  }
  .auth-subtitle {
    font-size: .9rem;
    color: #666;
    margin: 0;
  }

  /* ── Google button ── */
  .google-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    width: 100%;
    padding: .75rem 1.25rem;
    background: #fff;
    border: 1.5px solid #dadce0;
    border-radius: 8px;
    font-size: .9375rem;
    font-weight: 500;
    color: #3c4043;
    cursor: pointer;
    transition: background .15s, box-shadow .15s;
    text-decoration: none;
  }
  .google-btn:hover {
    background: #f8faff;
    box-shadow: 0 1px 6px rgba(66,133,244,.2);
    border-color: #b3c7f7;
  }
  .google-btn:active {
    background: #f0f4fe;
  }
  .google-btn__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* ── Divider ── */
  .auth-divider {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin: 1.5rem 0;
    color: #999;
    font-size: .8125rem;
  }
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #e5e7eb;
  }

  /* ── Fields ── */
  .field {
    margin-bottom: 1rem;
  }
  .field label {
    display: block;
    font-size: .8125rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: .375rem;
  }
  .field input {
    width: 100%;
    border: 1.5px solid #e5e7eb;
    border-radius: 8px;
    padding: .75rem 1rem;
    font-size: .9375rem;
    font-family: inherit;
    outline: none;
    transition: border-color .15s;
    background: #fff;
  }
  .field input:focus {
    border-color: #111;
  }

  .auth-forgot {
    text-align: right;
    margin-bottom: 1.25rem;
    margin-top: -.5rem;
  }
  .auth-forgot a {
    font-size: .8125rem;
    color: #555;
  }
  .auth-forgot a:hover { text-decoration: underline; }

  /* ── Primary button ── */
  .btn-primary {
    width: 100%;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: .875rem;
    font-size: .9375rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: background .15s;
  }
  .btn-primary:hover  { background: #333; }
  .btn-primary:active { background: #000; }

  .auth-switch {
    text-align: center;
    font-size: .875rem;
    color: #555;
    margin: 1.25rem 0 0;
  }
  .auth-switch a { font-weight: 600; color: #111; }
  .auth-switch a:hover { text-decoration: underline; }

  /* ── Shopify error messages ── */
  .errors ul { list-style: none; margin: 0 0 1rem; padding: 0; }
  .errors li {
    background: #fef2f2;
    color: #b91c1c;
    border: 1px solid #fecaca;
    border-radius: 6px;
    padding: .625rem .875rem;
    font-size: .875rem;
    margin-bottom: .5rem;
  }
</style>
