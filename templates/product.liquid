{%- comment -%}
  Shopify Native Product Template with Virtual Try-On
{%- endcomment -%}

<div class="product-page container mx-auto py-6 md:py-12 px-4 max-w-6xl">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

    <!-- Product Images -->
    <div class="product-images">
      <div class="main-image bg-gray-100 rounded-lg overflow-hidden aspect-[3/4]">
        <img
          id="main-product-image"
          src="{{ product.selected_or_first_available_variant.featured_image | default: product.featured_image | image_url: width: 1000 }}"
          alt="{{ product.title }}"
          class="w-full h-full object-cover transition-opacity duration-200"
        >
      </div>

      {%- comment -%}
        Each thumbnail carries data-image-url (full-size) and data-variant-id
        (the variant that "owns" this image, or blank for unlinked images).
        JS reads these attributes — no inline onclick with URL params.
      {%- endcomment -%}
      <div class="thumbnails flex gap-3 mt-4 overflow-x-auto pb-2" id="thumbnail-strip">
        {% for image in product.images %}
          {%- assign linked_variant_id = '' -%}
          {%- for variant in product.variants -%}
            {%- if variant.featured_image and variant.featured_image.id == image.id -%}
              {%- assign linked_variant_id = variant.id -%}
            {%- endif -%}
          {%- endfor -%}
          <button
            type="button"
            class="thumbnail-item w-20 h-28 sm:w-24 sm:h-32 flex-shrink-0 bg-gray-100 rounded cursor-pointer border-2 border-transparent hover:border-gray-400 transition-colors overflow-hidden focus:outline-none focus:ring-2 focus:ring-black"
            data-image-url="{{ image | image_url: width: 1000 }}"
            data-media-id="{{ image.id }}"
            data-variant-id="{{ linked_variant_id }}"
            aria-label="View image {{ forloop.index }} of {{ product.images.size }}"
          >
            <img src="{{ image | image_url: width: 200 }}" alt="{{ product.title }}" class="w-full h-full object-cover pointer-events-none">
          </button>
        {% endfor %}
      </div>
    </div>

    <!-- Product Info & Variant Selectors -->
    <div class="product-details flex flex-col">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-display font-bold mb-2">{{ product.title }}</h1>
      <p
        id="product-price"
        class="text-xl md:text-2xl font-medium text-gray-700 mb-4 md:mb-6"
        data-product-price
      >
        {{ product.selected_or_first_available_variant.price | money }}
      </p>

      <div class="product-description text-gray-600 leading-relaxed mb-8">
        {{ product.description }}
      </div>

      <!-- Add to Cart Form -->
      {% form 'product', product, class: 'product-form' %}
        <div class="variant-selectors space-y-4 mb-6">
          {% if product.variants.size > 1 %}
            {% for option in product.options_with_values %}
              <div class="selector-wrapper">
                <label class="block text-sm font-bold text-gray-700 mb-2" for="Option{{ forloop.index }}">
                  {{ option.name }}
                </label>
                <select
                  id="Option{{ forloop.index }}"
                  class="variant-select w-full border-2 border-gray-200 rounded-lg p-3 focus:border-black outline-none transition-colors"
                  data-option-index="{{ forloop.index0 }}"
                >
                  {% for value in option.values %}
                    <option
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}selected="selected"{% endif %}
                    >{{ value }}</option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}
          {% endif %}
        </div>

        {%- comment -%} Hidden master variant selector Shopify processes on form submit {%- endcomment -%}
        <select name="id" id="variant-id" class="hidden" aria-hidden="true">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              data-price="{{ variant.price | money }}"
              data-price-raw="{{ variant.price }}"
              data-image="{{ variant.featured_media | image_url: width: 1000 | default: variant.featured_image | image_url: width: 1000 }}"
              data-available="{{ variant.available }}"
              {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}
            >{{ variant.title }}</option>
          {% endfor %}
        </select>

        <button
          type="submit"
          id="add-to-cart-btn"
          class="w-full bg-black text-white font-bold py-4 rounded-lg hover:bg-gray-800 transition-colors mb-4 shadow-elegant disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Add to Cart
        </button>
      {% endform %}

      <!-- VIRTUAL TRY-ON AI FEATURE -->
      <div class="virtual-try-on-container border rounded-xl p-4 md:p-6 mt-6 md:mt-8 bg-white shadow-sm ring-1 ring-border">
        <div class="flex items-center gap-3 mb-3 md:mb-4">
          <svg class="w-5 h-5 md:w-6 md:h-6 text-black flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
          <h3 class="text-lg md:text-xl font-bold font-display">Virtual Try-On (AI)</h3>
          <span id="vto-quota-badge" class="ml-auto text-xs font-medium text-gray-400" aria-live="polite"></span>
        </div>

        <!-- Login gate: hidden by Liquid when logged in; JS double-checks on load -->
        <div id="vto-login-gate" {% if customer %}style="display:none"{% endif %}>
          <p class="text-sm text-gray-600 mb-4">Sign in to try on this item with AI — free for every account.</p>
          <a href="/account/login?return_url={{ request.path | url_encode }}" class="block w-full border-2 border-black bg-white text-black font-bold py-3 rounded hover:bg-gray-50 transition-colors text-center">
            Sign In to Try On
          </a>
        </div>

        <!-- Main VTO UI: hidden by Liquid when logged out; JS double-checks on load -->
        <div id="vto-main-ui" {% unless customer %}style="display:none"{% endunless %}>
          <p class="text-sm text-gray-600 mb-4">Upload a photo of yourself to see how this item looks on you.</p>
          <div class="vto-upload-area mb-4">
            <input type="file" id="vto-user-image" accept="image/*" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-gray-100 file:text-gray-700 hover:file:bg-gray-200 transition-colors cursor-pointer border border-dashed border-gray-300 rounded-md p-2">
          </div>
          <button id="vto-generate-btn" class="w-full border-2 border-black bg-white text-black font-bold py-3 rounded hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
            Generate AI Preview
          </button>
          <div id="vto-upgrade-prompt" class="hidden mt-3 rounded-lg border border-[#F2EBE3] bg-[#FAF8F5] p-3 text-center text-sm">
            <p class="text-gray-700 mb-1">You've used all 3 free try-ons.</p>
            <a href="/pages/pricing" class="font-semibold text-black underline underline-offset-2">Upgrade to Layered Pro</a><span class="text-gray-500"> for 100 per month.</span>
          </div>
          <div id="vto-loading" class="hidden mt-6 flex flex-col items-center justify-center p-8 border rounded bg-gray-50">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-black"></div>
            <p class="mt-4 text-sm font-medium text-gray-700">AI is rendering your look...</p>
          </div>
          <div id="vto-result-container" class="hidden mt-6">
            <h4 class="font-medium mb-3 text-center">Your Virtual Look</h4>
            <div class="aspect-[3/4] rounded-lg overflow-hidden border shadow-sm">
              <img id="vto-result-image" src="" alt="Virtual Try-On Result" class="w-full h-full object-cover">
            </div>
            <div class="mt-3 flex items-center justify-end gap-3">
              <button
                id="vto-download-btn"
                type="button"
                class="hidden text-xs font-medium border border-gray-300 rounded-lg px-4 py-2 hover:border-black transition-colors"
              >
                Download image
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="product-variants-data">
  [
    {% for variant in product.variants %}
    {
      "id": {{ variant.id }},
      "title": {{ variant.title | json }},
      "price": {{ variant.price | money | json }},
      "available": {{ variant.available | json }},
      "image": {{ variant.featured_media | image_url: width: 1000 | default: variant.featured_image | image_url: width: 1000 | json }},
      "mediaId": {{ variant.featured_media.id | default: variant.featured_image.id | json }},
      "options": [{% for opt in variant.options %}{{ opt | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
</script>

<script type="application/json" id="product-vto-config">
  {
    "productTitle": {{ product.title | json }},
    "productType": {{ product.product_type | json }},
    "customerEmail": {{ customer.email | default: "" | json }},
    "isProMember": {% if customer and customer.tags contains 'Pro Member' %}true{% else %}false{% endif %}
  }
</script>

<script src="{{ 'product-vto.js' | asset_url }}" defer></script>
