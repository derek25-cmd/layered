{%- comment -%} ── Navbar — mirrors Navbar.tsx layout & behaviour ── {%- endcomment -%}
<header id="lp-header" class="lp-nav fixed top-0 inset-x-0 z-50 py-5 transition-all duration-500">
  <div class="container max-w-7xl mx-auto px-6 flex items-center justify-between gap-6">

    {%- comment -%} Logo — 3-layer stacked bars matching Navbar.tsx {%- endcomment -%}
    <a href="/" class="flex items-center gap-2 group" aria-label="Layered home">
      <div class="lp-logo-layers relative w-7 h-7 flex-shrink-0">
        <div class="absolute inset-x-0 top-0     h-[6px] lp-bar lp-bar--top rounded-sm transition-transform group-hover:-translate-y-0.5"></div>
        <div class="absolute inset-x-1 top-[10px] h-[6px] lp-bar lp-bar--mid rounded-sm"></div>
        <div class="absolute inset-x-2 top-[20px] h-[6px] lp-bar lp-bar--bot rounded-sm transition-transform group-hover:translate-y-0.5"></div>
      </div>
      <span class="font-display text-2xl tracking-tight lp-logo-text">Layered</span>
    </a>

    {%- comment -%} Desktop nav links {%- endcomment -%}
    <nav class="hidden md:flex items-center gap-8">
      <a href="https://layered-2139.myshopify.com/shop" class="lp-nav-link">Shop</a>
      <a href="/outfit-builder" class="lp-nav-link">Create Outfit</a>
      <a href="/ai-assistant" class="lp-nav-link">AI Stylist</a>
    </nav>

    {%- comment -%} Right rail — outfit icon + cart, mirroring Navbar.tsx right slot {%- endcomment -%}
    <div class="flex items-center gap-1">
      <a href="/outfit-builder" class="lp-icon-btn hidden sm:flex items-center relative" aria-label="Outfit builder">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3a2 2 0 00-2 2v14a2 2 0 002 2h3m6 0h3a2 2 0 002-2V5a2 2 0 00-2-2H5"/><polyline points="9 3 9 8 12 11 15 8 15 3"/></svg>
      </a>
      <a href="/cart" class="lp-icon-btn flex items-center relative" aria-label="Shopping bag">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </a>
      <button id="pr-menu-toggle" class="lp-icon-btn md:hidden" aria-label="Menu" aria-expanded="false" aria-controls="pr-mobile-menu">
        <svg id="pr-icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="3" y1="6"  x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="pr-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  {%- comment -%} Mobile menu — glass panel matching Navbar.tsx animate-fade-in {%- endcomment -%}
  <div id="pr-mobile-menu" class="md:hidden hidden lp-mobile-panel border-t lp-mobile-border">
    <nav class="container max-w-7xl mx-auto px-6 py-6 flex flex-col gap-4">
      <a href="https://layered-2139.myshopify.com/shop" class="text-lg font-display lp-mobile-link">Shop</a>
      <a href="/outfit-builder" class="text-lg font-display lp-mobile-link">Create Outfit</a>
      <a href="/ai-assistant" class="text-lg font-display lp-mobile-link">AI Stylist</a>
    </nav>
  </div>
</header>

<div class="lp-page min-h-screen pt-20 overflow-hidden">
  {%- assign pro_product = all_products['layered-pro-plan'] -%}

  {%- comment -%} Background subtle texture ── {%- endcomment -%}
  <div class="lp-bg-accent" aria-hidden="true"></div>

  <div class="container max-w-7xl mx-auto px-8 py-24 relative z-10">

    {%- comment -%} ── Heading ── {%- endcomment -%}
    <div class="lp-pricing-hero mb-28 reveal">
      <div class="lp-pricing-hero-inner">
        <p class="lp-eyebrow mb-5">Elevate your experience</p>
        <h1 class="lp-display">Premium care for your <span class="lp-display--italic">style.</span></h1>
        <div class="lp-hero-rule"></div>
        <p class="lp-hero-body mt-8">Choose the plan that fits your journey. One for the essentials, one for those who want it all.</p>
      </div>
    </div>

    {%- comment -%} ── Plans ── {%- endcomment -%}
    <div class="lp-plans-grid mb-28">

      {%- comment -%} Free ── {%- endcomment -%}
      <div class="lp-plan lp-plan--free reveal" style="transition-delay: 80ms">
        <div class="lp-plan-top">
          <div>
            <p class="lp-label mb-4">The Starting Point</p>
            <h2 class="lp-plan-name">Essential</h2>
          </div>
          <div class="text-right">
            <span class="lp-price">£0</span>
            <span class="lp-price-note block">Forever</span>
          </div>
        </div>

        <p class="lp-plan-desc">Perfect for discovering your style and exploring the Layered catalogue.</p>

        <ul class="lp-features">
          {%- assign free_features = 'Full product catalogue,AI Stylist (5/day),Outfit builder (save up to 3),Virtual Try-On (2/day)' | split: ',' -%}
          {%- assign free_no = '15% off every order,Free shipping,Priority new drops,Unlimited saves' | split: ',' -%}
          {% for f in free_features %}
            <li class="lp-feature lp-feature--yes">
              <span class="lp-feature-icon lp-feature-icon--yes">
                <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {{ f }}
            </li>
          {% endfor %}
          {% for f in free_no %}
            <li class="lp-feature lp-feature--no">
              <span class="lp-feature-icon lp-feature-icon--no">
                <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M5.5 10.5l5-5M10.5 10.5l-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              </span>
              {{ f }}
            </li>
          {% endfor %}
        </ul>

        <div class="lp-plan-cta">
          {% if customer %}
            <div class="lp-plan-active">Active Plan</div>
          {% else %}
            <a href="{{ routes.account_login_url }}" class="lp-btn-outline lp-btn-outline--dark w-full block text-center">
              Get Started
            </a>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Pro ── {%- endcomment -%}
      <div class="lp-plan lp-plan--pro reveal" style="transition-delay: 180ms">
        <div class="lp-plan-badge">Recommended</div>

        <div class="lp-plan-top">
          <div>
            <p class="lp-label lp-label--light mb-4">The Full Experience</p>
            <h2 class="lp-plan-name lp-plan-name--pro">Layered Pro</h2>
          </div>
          <div class="text-right">
            <span class="lp-price lp-price--pro">£20</span>
            <span class="lp-price-note lp-price-note--pro block">Per Month</span>
          </div>
        </div>

        <p class="lp-plan-desc lp-plan-desc--pro">Everything you need to build a world-class wardrobe with zero friction.</p>

        <ul class="lp-features">
          {%- assign pro_features = '15% off every order always,100 AI Virtual Try-On images,Free shipping on all orders,Priority access to new drops,Unlimited outfit saves,Unlimited AI Stylist,Early access to limited pieces,Dedicated style support' | split: ',' -%}
          {% for f in pro_features %}
            <li class="lp-feature lp-feature--pro-item">
              <span class="lp-feature-icon lp-feature-icon--pro">
                <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {{ f }}
            </li>
          {% endfor %}
        </ul>

        <div class="lp-plan-cta">
          {% if customer and customer.tags contains 'Pro Member' %}
            <div class="lp-plan-active lp-plan-active--pro">Current Membership</div>
            <a href="mailto:{{ shop.email }}?subject=Cancel+Layered+Pro+Membership&body=Hi%2C+I+would+like+to+cancel+my+Layered+Pro+membership.+My+account+email+is+{{ customer.email | url_encode }}." class="lp-cancel-link">Cancel Membership</a>
          {% else %}
            {%- comment -%}
              We use a button + JS to call Shopify's Storefront API cartCreate directly,
              matching the headless cartStore.ts flow, so we get a proper checkoutUrl
              (with ?channel=online_store) rather than the legacy /cart/ route.
              The variant ID is passed via data-variant-id rendered server-side by Liquid.
            {%- endcomment -%}
            <button
              id="pr-upgrade-btn"
              data-variant-id="{{ pro_product.first_available_variant.id }}"
              class="lp-btn-primary-inv w-full block text-center"
              aria-label="Upgrade to Layered Pro"
            >
              <span id="pr-upgrade-label">Upgrade Now</span>
              <span id="pr-upgrade-spinner" class="lp-spinner hidden" aria-hidden="true"></span>
            </button>
            <p class="lp-instant-note">Instant Access · Cancel Anytime</p>
          {% endif %}
        </div>
      </div>

    </div>

    {%- comment -%} ── Pro perks in detail ── {%- endcomment -%}
    <div class="lp-perks-section mb-28">
      <div class="lp-section-divider"></div>
      <p class="lp-eyebrow mb-14">Pro Perks in Detail</p>
      <div class="lp-perks-grid">

        <div class="lp-perk reveal" style="transition-delay: 200ms">
          <p class="lp-perk-stat">15%</p>
          <p class="lp-perk-title">Off Every Order</p>
          <p class="lp-perk-body">Applied automatically at checkout, every single time. No codes, no hassle.</p>
        </div>

        <div class="lp-perk reveal" style="transition-delay: 300ms">
          <p class="lp-perk-stat">100</p>
          <p class="lp-perk-title">AI Generations</p>
          <p class="lp-perk-body">Perfectly visualize any piece on yourself with high-fidelity AI virtual try-on.</p>
        </div>

        <div class="lp-perk reveal" style="transition-delay: 400ms">
          <p class="lp-perk-stat">1st</p>
          <p class="lp-perk-title">Priority Access</p>
          <p class="lp-perk-body">Get notified 24 hours before anyone else when limited collections drop.</p>
        </div>

      </div>
    </div>

    {%- comment -%} ── FAQ ── {%- endcomment -%}
    <div class="lp-faq-section reveal" style="transition-delay: 500ms">
      <p class="lp-eyebrow mb-14">Common Questions</p>
      <div class="lp-faq-list">

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">When does the 15% discount apply?</summary>
          <p class="lp-faq-body">It's applied automatically at checkout on every order while your membership is active. You'll see the savings reflected in your subtotal.</p>
        </details>

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">How do image generations work?</summary>
          <p class="lp-faq-body">Each time you use the "Virtual Try-On" feature to generate a preview of a product on your photo, it counts as one generation. Pro members get 100 per month.</p>
        </details>

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">Can I cancel anytime?</summary>
          <p class="lp-faq-body">Absolutely. You can manage your subscription from your account dashboard. Your benefits will remain active until the end of your current billing cycle.</p>
        </details>

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">Is there a contract?</summary>
          <p class="lp-faq-body">No contracts or hidden fees. Layered Pro is a simple monthly subscription that you control.</p>
        </details>

      </div>
    </div>

  </div>
</div>

{%- comment -%} ── Pro Activation Dialog ── {%- endcomment -%}
<div id="lp-pro-dialog" class="lp-dialog-overlay" role="dialog" aria-modal="true" aria-labelledby="lp-dialog-title">
  <div class="lp-dialog">
    <button class="lp-dialog-close" id="lp-dialog-close" aria-label="Close">✕</button>

    <div id="lp-dialog-success">
      <div class="lp-dialog-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" fill="#0E0E0E" opacity="0.55"/></svg>
      </div>
      <p class="lp-eyebrow mb-3">Membership Activated</p>
      <h2 id="lp-dialog-title" class="lp-dialog-heading">Welcome to Layered Pro<span class="lp-dialog-heading--italic">.</span></h2>
      <div class="lp-dialog-rule"></div>
      <ul class="lp-dialog-perks">
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>15% off every order, applied automatically</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>100 AI Virtual Try-On generations per month</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>Free shipping on every order</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>24-hour early access to new drops</li>
      </ul>
      <a href="/collections/all" class="lp-btn-primary-inv lp-dialog-cta">Shop with Pro</a>
    </div>

    <div id="lp-dialog-activating" style="display:none">
      <div class="lp-dialog-icon lp-dialog-icon--pulse">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      </div>
      <p class="lp-eyebrow mb-3">One moment</p>
      <h2 class="lp-dialog-heading">Activating your membership<span class="lp-dialog-heading--italic">.</span></h2>
      <div class="lp-dialog-rule"></div>
      <p class="lp-body-muted" style="font-size:0.9rem">Your Pro membership is being confirmed. This page will refresh automatically in a few seconds.</p>
    </div>
  </div>
</div>

<style>
  /* ── Layered Pricing — Redesign ──────────────────────────────────────────── */
  :root {
    --beige: #F2EBE3;
    --beige-dark: #E8DDD3;
    --beige-mid: #D4C9BE;
    --black: #0E0E0E;
    --off-black: #1A1A1A;
    --white: #FFFFFF;
    --cream: #FAF8F5;
  }

  /* ── Base ───────────────────────────────────────────────────────────────── */
  .lp-page {
    background-color: var(--cream);
    color: var(--black);
    font-family: 'Inter', system-ui, sans-serif;
  }

  .lp-bg-accent {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 80% 15%, rgba(242,235,227,0.55) 0%, transparent 65%),
      radial-gradient(ellipse 40% 50% at 10% 85%, rgba(242,235,227,0.3) 0%, transparent 60%);
    z-index: 0;
  }

    /* ══ Navbar — mirrors Navbar.tsx ═════════════════════════════════════════ */

  /* Base — transparent + py-5 (matches `py-5 bg-transparent` in Navbar.tsx) */
  .lp-nav {
    transition: background 0.5s ease, padding-top 0.5s ease, padding-bottom 0.5s ease, box-shadow 0.3s ease;
  }

  /* Scrolled — glass + py-3 (matches `glass py-3` className in Navbar.tsx)  */
  .lp-nav.lp-nav--scrolled {
    background: rgba(250, 248, 245, 0.88) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(14,14,14,0.07);
    padding-top: 0.75rem !important;
    padding-bottom: 0.75rem !important;
  }

  /* 3-layer stacked logo bars — foreground / secondary / muted             */
  .lp-bar { background: var(--black); }
  .lp-bar--top { opacity: 1.0; }
  .lp-bar--mid { opacity: 0.45; }
  .lp-bar--bot { opacity: 0.2; }

  .lp-logo-text {
    color: var(--black);
    letter-spacing: -0.04em;
  }

  /* Desktop nav links — text-sm uppercase underline pattern from Navbar.tsx */
  .lp-nav-link {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    color: rgba(14,14,14,0.55);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.2s ease;
  }

  .lp-nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    height: 1px;
    background: var(--black);
    width: 0;
    transition: width 0.25s ease;
  }

  .lp-nav-link:hover              { color: var(--black); }
  .lp-nav-link:hover::after       { width: 100%; }
  .lp-nav-link--active            { color: var(--black); }
  .lp-nav-link--active::after     { width: 100%; }

  /* Icon buttons — right rail (matches Navbar.tsx hover:bg-foreground/5 rounded-full) */
  .lp-icon-btn {
    padding: 8px;
    color: var(--black);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 9999px;
    transition: background 0.2s ease;
    text-decoration: none;
  }
  .lp-icon-btn:hover { background: rgba(14,14,14,0.06); }

  /* Mobile panel — glass + animate-fade-in (matches Navbar.tsx mobile open) */
  .lp-mobile-panel {
    background: rgba(250,248,245,0.96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    animation: lp-fade-in 0.18s ease forwards;
  }
  .lp-mobile-border { border-color: rgba(14,14,14,0.08); }

  /* Mobile links — font-display italic (matches Navbar.tsx `text-lg font-display`) */
  .lp-mobile-link {
    font-style: italic;
    color: rgba(14,14,14,0.55);
    text-decoration: none;
    transition: color 0.2s ease;
    font-weight: 400;
    letter-spacing: -0.02em;
  }
  .lp-mobile-link:hover { color: var(--black); }

  @keyframes lp-fade-in {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Hero ───────────────────────────────────────────────────────────────── */
  .lp-pricing-hero { max-width: 700px; }

  .lp-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(14, 14, 14, 0.35);
    font-weight: 600;
    display: block;
  }

  .lp-display {
    font-family: 'Fraunces', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--black);
    font-weight: 400;
    margin: 0;
  }

  .lp-display--italic {
    font-style: italic;
    color: rgba(14, 14, 14, 0.22);
  }

  .lp-hero-rule {
    width: 56px;
    height: 1px;
    background: var(--beige-mid);
    margin-top: 2rem;
  }

  .lp-hero-body {
    font-size: 1.05rem;
    color: rgba(14, 14, 14, 0.5);
    line-height: 1.7;
    max-width: 400px;
  }

  /* ── Plans grid ─────────────────────────────────────────────────────────── */
  .lp-plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }

  @media (min-width: 768px) {
    .lp-plans-grid { grid-template-columns: 1fr 1fr; }
  }

  .lp-plan {
    padding: 3rem 3.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .lp-plan--free {
    background: var(--white);
    border: 1px solid rgba(14, 14, 14, 0.08);
    transition: border-color 0.3s ease;
  }

  .lp-plan--free:hover { border-color: rgba(14, 14, 14, 0.2); }

  .lp-plan--pro {
    background: var(--black);
    color: var(--white);
    overflow: hidden;
  }

  .lp-plan--pro::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(242,235,227,0.06) 100%);
    pointer-events: none;
  }

  .lp-plan-badge {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: var(--beige);
    color: var(--black);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-weight: 700;
    padding: 6px 14px;
  }

  .lp-plan-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .lp-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: rgba(14, 14, 14, 0.35);
  }

  .lp-label--light { color: rgba(255,255,255,0.35); }

  .lp-plan-name {
    font-family: 'Fraunces', serif;
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--black);
    font-style: italic;
    margin-top: 4px;
  }

  .lp-plan-name--pro { color: var(--white); }

  .lp-price {
    font-family: 'Fraunces', serif;
    font-size: 3rem;
    font-weight: 400;
    color: var(--black);
    letter-spacing: -0.03em;
  }

  .lp-price--pro { color: var(--white); }

  .lp-price-note {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: rgba(14, 14, 14, 0.3);
    margin-top: 4px;
  }

  .lp-price-note--pro { color: rgba(255,255,255,0.3); }

  .lp-plan-desc {
    font-size: 0.875rem;
    color: rgba(14, 14, 14, 0.48);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .lp-plan-desc--pro { color: rgba(255,255,255,0.48); }

  /* ── Feature list ───────────────────────────────────────────────────────── */
  .lp-features {
    list-style: none;
    margin: 0 0 2.5rem 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .lp-feature {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 0.875rem;
  }

  .lp-feature--yes { color: rgba(14, 14, 14, 0.72); font-weight: 500; }
  .lp-feature--no  { color: rgba(14, 14, 14, 0.22); text-decoration: line-through; text-decoration-color: rgba(14,14,14,0.1); }
  .lp-feature--pro-item { color: rgba(255,255,255,0.75); font-weight: 500; }

  .lp-feature-icon {
