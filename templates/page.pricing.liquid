{% comment %} Pricing — uses SPA design tokens from layered-app.css {% endcomment %}

{%- comment -%} ── Minimal site nav for native pages ── {%- endcomment -%}
<header class="fixed top-0 inset-x-0 z-50 border-b border-foreground/10 bg-background/80 backdrop-blur-md">
  <div class="container max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="font-display text-xl text-foreground">Layered</a>
    <nav class="hidden md:flex items-center gap-7">
      <a href="/collections/all" class="text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Shop</a>
      <a href="/outfits" class="text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Outfits</a>
      <a href="/ai-assistant" class="text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">AI Stylist</a>
      <a href="/pages/profile" class="text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Profile</a>
      <a href="/pages/pricing" class="text-xs uppercase tracking-wider text-foreground border-b border-foreground pb-0.5">Pricing</a>
      {% if customer %}
        <a href="/account" class="text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="text-xs uppercase tracking-wider text-muted-foreground hover:text-foreground transition-colors">Sign in</a>
      {% endif %}
    </nav>
    <button id="pr-menu-toggle" class="md:hidden p-2 -mr-2 text-foreground" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>
  </div>
  <div id="pr-mobile-menu" class="md:hidden hidden border-t border-foreground/10 bg-background">
    <div class="container max-w-7xl mx-auto px-4 py-5 flex flex-col gap-4">
      <a href="/collections/all" class="text-base font-display text-foreground/70 hover:text-foreground">Shop</a>
      <a href="/outfits" class="text-base font-display text-foreground/70 hover:text-foreground">Outfits</a>
      <a href="/ai-assistant" class="text-base font-display text-foreground/70 hover:text-foreground">AI Stylist</a>
      <a href="/pages/profile" class="text-base font-display text-foreground/70 hover:text-foreground">Profile</a>
      <a href="/pages/pricing" class="text-base font-display text-foreground">Pricing</a>
      {% if customer %}
        <a href="/account" class="text-base font-display text-foreground/70 hover:text-foreground">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="text-base font-display text-foreground/70 hover:text-foreground">Sign in</a>
      {% endif %}
    </div>
  </div>
</header>

<div class="min-h-screen bg-background text-foreground pt-14">
  <div class="container max-w-7xl mx-auto px-4 py-16 md:py-20">

    {%- comment -%} ── Heading ── {%- endcomment -%}
    <div class="max-w-2xl mb-16 md:mb-20">
      <p class="text-xs tracking-[0.25em] uppercase text-muted-foreground mb-3">Membership</p>
      <h1 class="font-display text-5xl md:text-7xl leading-tight mb-4">Simple, honest<span class="italic"> pricing.</span></h1>
      <p class="text-sm text-muted-foreground max-w-md">One plan. Every perk. For people who build their wardrobe with intention.</p>
    </div>

    {%- comment -%} ── Plans ── {%- endcomment -%}
    <div class="grid md:grid-cols-2 gap-px bg-foreground/10 mb-16 md:mb-20">

      {%- comment -%} Free ── {%- endcomment -%}
      <div class="bg-background p-8 md:p-10">
        <p class="text-[10px] uppercase tracking-widest text-muted-foreground mb-4">Free</p>
        <div class="mb-6">
          <span class="font-display text-6xl">£0</span>
          <span class="text-sm text-muted-foreground">/month</span>
        </div>
        <p class="text-sm text-muted-foreground mb-8">The essentials, always free.</p>
        <ul class="space-y-3 mb-10">
          {%- assign free_features = 'Full product catalogue,AI Stylist (5/day),Outfit builder (save up to 3),Virtual Try-On (2/day)' | split: ',' -%}
          {%- assign free_no = '20% off every order,Free shipping,Priority new drops,Unlimited saves' | split: ',' -%}
          {% for f in free_features %}
            <li class="flex items-center gap-3 text-sm">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".4"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ f }}
            </li>
          {% endfor %}
          {% for f in free_no %}
            <li class="flex items-center gap-3 text-sm text-muted-foreground/50">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7.5" stroke="currentColor" stroke-opacity=".2"/><path d="M5.5 10.5l5-5M10.5 10.5l-5-5" stroke="currentColor" stroke-opacity=".3" stroke-width="1.5" stroke-linecap="round"/></svg>
              {{ f }}
            </li>
          {% endfor %}
        </ul>
        {% if customer %}
          <div class="border border-foreground/10 px-6 py-3 text-center text-xs uppercase tracking-wider text-muted-foreground">Your current plan</div>
        {% else %}
          <a href="{{ routes.account_login_url }}" class="block text-center border border-foreground/20 px-6 py-3 text-xs uppercase tracking-wider hover:border-foreground transition-colors">
            Get started free
          </a>
        {% endif %}
      </div>

      {%- comment -%} Pro ── {%- endcomment -%}
      <div class="bg-foreground text-background p-8 md:p-10 relative">
        <div class="absolute top-6 right-6 text-[9px] uppercase tracking-widest border border-background/30 px-2.5 py-1 text-background/70">Best value</div>
        <p class="text-[10px] uppercase tracking-widest text-background/50 mb-4">Layered Pro</p>
        <div class="mb-6">
          <span class="font-display text-6xl">£9.99</span>
          <span class="text-sm text-background/50">/month</span>
        </div>
        <p class="text-sm text-background/60 mb-8">Everything in Free, plus exclusive perks.</p>
        <ul class="space-y-3 mb-10">
          {%- assign pro_features = '20% off every order always,Free shipping on all orders,Priority access to new drops,Unlimited outfit saves,Unlimited AI Stylist,Unlimited Virtual Try-On,Early access to limited pieces,Dedicated style support' | split: ',' -%}
          {% for f in pro_features %}
            <li class="flex items-center gap-3 text-sm text-background/80">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7.5" stroke="white" stroke-opacity=".5"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ f }}
            </li>
          {% endfor %}
        </ul>
        {% if customer and customer.tags contains 'Pro Member' %}
          <div class="bg-background/20 text-background px-6 py-3 text-center text-xs uppercase tracking-wider">Active — enjoy your perks ✦</div>
        {% else %}
          <a href="/products/layered-pro-plan" class="block text-center bg-background text-foreground px-6 py-3 text-xs uppercase tracking-wider font-semibold hover:bg-background/90 transition-colors">
            Upgrade to Pro
          </a>
          <p class="text-center text-[10px] text-background/40 mt-3">Cancel anytime · No hidden fees</p>
        {% endif %}
      </div>

    </div>

    {%- comment -%} ── What Pro means concretely ── {%- endcomment -%}
    <div class="border-t border-foreground/10 pt-16 mb-16">
      <p class="text-xs tracking-[0.25em] uppercase text-muted-foreground mb-8">Pro in practice</p>
      <div class="grid md:grid-cols-3 gap-px bg-foreground/10">
        <div class="bg-background p-6 md:p-8">
          <p class="font-display text-3xl mb-3">20%</p>
          <p class="text-xs uppercase tracking-widest text-muted-foreground mb-2">Off every order</p>
          <p class="text-sm text-muted-foreground">Applied automatically at checkout, every single time. No code needed.</p>
        </div>
        <div class="bg-background p-6 md:p-8">
          <p class="font-display text-3xl mb-3">∞</p>
          <p class="text-xs uppercase tracking-widest text-muted-foreground mb-2">Unlimited saves</p>
          <p class="text-sm text-muted-foreground">Build and save as many outfits as you want. No caps, no limits.</p>
        </div>
        <div class="bg-background p-6 md:p-8">
          <p class="font-display text-3xl mb-3">1st</p>
          <p class="text-xs uppercase tracking-widest text-muted-foreground mb-2">Early access</p>
          <p class="text-sm text-muted-foreground">Get notified before anyone else when new layers drop.</p>
        </div>
      </div>
    </div>

    {%- comment -%} ── FAQ ── {%- endcomment -%}
    <div class="max-w-2xl">
      <p class="text-xs tracking-[0.25em] uppercase text-muted-foreground mb-8">Questions</p>
      <div class="divide-y divide-foreground/10">

        <details class="pr-faq group">
          <summary>When does the 20% discount apply?</summary>
          <p>It's applied automatically at checkout on every order while your membership is active. There's no code to remember.</p>
        </details>

        <details class="pr-faq group">
          <summary>Can I cancel anytime?</summary>
          <p>Yes — cancel from your Shopify account at any time. Your benefits remain active until the end of the billing period.</p>
        </details>

        <details class="pr-faq group">
          <summary>Does it work with sale prices?</summary>
          <p>The Pro discount applies to standard pricing. Sale items may have different terms noted on the product page.</p>
        </details>

        <details class="pr-faq group">
          <summary>How do I access Pro features after subscribing?</summary>
          <p>Your account is upgraded automatically. Sign out and back in if features don't appear immediately.</p>
        </details>

        <details class="pr-faq group">
          <summary>Is the Pro Plan a physical product?</summary>
          <p>No — it's a digital subscription that unlocks perks on your account. Nothing is shipped.</p>
        </details>

      </div>
    </div>

  </div>
</div>

<style>
  .pr-faq summary {
    cursor: pointer;
    list-style: none;
    padding: 1rem 0;
    font-size: .9375rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
  }
  .pr-faq summary::-webkit-details-marker { display: none; }
  .pr-faq summary::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: hsl(var(--muted-foreground));
    flex-shrink: 0;
  }
  .pr-faq[open] summary::after { content: '−'; }
  .pr-faq p {
    padding: 0 0 1rem;
    margin: 0;
    font-size: .875rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.7;
  }
</style>

<script>
(function() {
  const toggle = document.getElementById('pr-menu-toggle');
  const menu   = document.getElementById('pr-mobile-menu');
  if (toggle && menu) toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
})();
</script>
