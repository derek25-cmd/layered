{% comment %} Pricing — uses SPA design tokens from layered-app.css {% endcomment %}

{%- comment -%} ── Minimal site nav for native pages ── {%- endcomment -%}
<header class="lp-nav fixed top-0 inset-x-0 z-50">
  <div class="lp-nav-inner container max-w-7xl mx-auto px-8 h-[72px] flex items-center justify-between">
    <a href="/" class="lp-logo font-display text-xl tracking-tighter group flex items-center gap-3">
      <span class="lp-logo-mark w-9 h-9 flex items-center justify-center font-bold text-sm transition-transform duration-500 group-hover:rotate-12">L</span>
      Layered
    </a>
    <nav class="hidden md:flex items-center gap-10">
      <a href="/collections/all" class="lp-nav-link">Shop</a>
      <a href="/outfits" class="lp-nav-link">Outfits</a>
      <a href="/ai-assistant" class="lp-nav-link">AI Stylist</a>
      <a href="/pages/profile" class="lp-nav-link">Profile</a>
      <a href="/pages/pricing" class="lp-nav-link lp-nav-link--active">Pricing</a>
      {% if customer %}
        <a href="/account" class="lp-nav-link">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="lp-nav-link">Sign in</a>
      {% endif %}
    </nav>
    <button id="pr-menu-toggle" class="lp-hamburger md:hidden" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M3 8h18M3 16h18"/></svg>
    </button>
  </div>
  <div id="pr-mobile-menu" class="lp-mobile-menu hidden md:hidden">
    <div class="container max-w-7xl mx-auto px-8 py-12 flex flex-col gap-7">
      <a href="/collections/all" class="lp-mobile-link">Shop</a>
      <a href="/outfits" class="lp-mobile-link">Outfits</a>
      <a href="/ai-assistant" class="lp-mobile-link">AI Stylist</a>
      <a href="/pages/profile" class="lp-mobile-link">Profile</a>
      <a href="/pages/pricing" class="lp-mobile-link lp-mobile-link--active">Pricing</a>
      {% if customer %}
        <a href="/account" class="lp-mobile-link">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="lp-mobile-link">Sign in</a>
      {% endif %}
    </div>
  </div>
</header>

<div class="lp-page min-h-screen pt-[72px] overflow-hidden">
  {%- assign pro_product = all_products['layered-pro-plan'] -%}

  {%- comment -%} Background subtle texture ── {%- endcomment -%}
  <div class="lp-bg-accent" aria-hidden="true"></div>

  <div class="container max-w-7xl mx-auto px-8 py-24 relative z-10">

    {%- comment -%} ── Heading ── {%- endcomment -%}
    <div class="lp-pricing-hero mb-28 reveal">
      <div class="lp-pricing-hero-inner">
        <p class="lp-eyebrow mb-5">Elevate your experience</p>
        <h1 class="lp-display">Premium care for your <span class="lp-display--italic">style.</span></h1>
        <div class="lp-hero-rule"></div>
        <p class="lp-hero-body mt-8">Choose the plan that fits your journey. One for the essentials, one for those who want it all.</p>
      </div>
    </div>

    {%- comment -%} ── Plans ── {%- endcomment -%}
    <div class="lp-plans-grid mb-28">

      {%- comment -%} Free ── {%- endcomment -%}
      <div class="lp-plan lp-plan--free reveal" style="transition-delay: 80ms">
        <div class="lp-plan-top">
          <div>
            <p class="lp-label mb-4">The Starting Point</p>
            <h2 class="lp-plan-name">Essential</h2>
          </div>
          <div class="text-right">
            <span class="lp-price">£0</span>
            <span class="lp-price-note block">Forever</span>
          </div>
        </div>

        <p class="lp-plan-desc">Perfect for discovering your style and exploring the Layered catalogue.</p>

        <ul class="lp-features">
          {%- assign free_features = 'Full product catalogue,AI Stylist (5/day),Outfit builder (save up to 3),Virtual Try-On (2/day)' | split: ',' -%}
          {%- assign free_no = '15% off every order,Free shipping,Priority new drops,Unlimited saves' | split: ',' -%}
          {% for f in free_features %}
            <li class="lp-feature lp-feature--yes">
              <span class="lp-feature-icon lp-feature-icon--yes">
                <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {{ f }}
            </li>
          {% endfor %}
          {% for f in free_no %}
            <li class="lp-feature lp-feature--no">
              <span class="lp-feature-icon lp-feature-icon--no">
                <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M5.5 10.5l5-5M10.5 10.5l-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              </span>
              {{ f }}
            </li>
          {% endfor %}
        </ul>

        <div class="lp-plan-cta">
          {% if customer %}
            <div class="lp-plan-active">Active Plan</div>
          {% else %}
            <a href="{{ routes.account_login_url }}" class="lp-btn-outline lp-btn-outline--dark w-full block text-center">
              Get Started
            </a>
          {% endif %}
        </div>
      </div>

      {%- comment -%} Pro ── {%- endcomment -%}
      <div class="lp-plan lp-plan--pro reveal" style="transition-delay: 180ms">
        <div class="lp-plan-badge">Recommended</div>

        <div class="lp-plan-top">
          <div>
            <p class="lp-label lp-label--light mb-4">The Full Experience</p>
            <h2 class="lp-plan-name lp-plan-name--pro">Layered Pro</h2>
          </div>
          <div class="text-right">
            <span class="lp-price lp-price--pro">£20</span>
            <span class="lp-price-note lp-price-note--pro block">Per Month</span>
          </div>
        </div>

        <p class="lp-plan-desc lp-plan-desc--pro">Everything you need to build a world-class wardrobe with zero friction.</p>

        <ul class="lp-features">
          {%- assign pro_features = '15% off every order always,100 AI Virtual Try-On images,Free shipping on all orders,Priority access to new drops,Unlimited outfit saves,Unlimited AI Stylist,Early access to limited pieces,Dedicated style support' | split: ',' -%}
          {% for f in pro_features %}
            <li class="lp-feature lp-feature--pro-item">
              <span class="lp-feature-icon lp-feature-icon--pro">
                <svg width="9" height="9" viewBox="0 0 16 16" fill="none"><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {{ f }}
            </li>
          {% endfor %}
        </ul>

        <div class="lp-plan-cta">
          {% if customer and customer.tags contains 'Pro Member' %}
            <div class="lp-plan-active lp-plan-active--pro">Current Membership</div>
          {% else %}
            {%- comment -%}
              We use a button + JS to call Shopify's Storefront API cartCreate directly,
              matching the headless cartStore.ts flow, so we get a proper checkoutUrl
              (with ?channel=online_store) rather than the legacy /cart/ route.
              The variant ID is passed via data-variant-id rendered server-side by Liquid.
            {%- endcomment -%}
            <button
              id="pr-upgrade-btn"
              data-variant-id="{{ pro_product.first_available_variant.id }}"
              class="lp-btn-primary-inv w-full block text-center"
              aria-label="Upgrade to Layered Pro"
            >
              <span id="pr-upgrade-label">Upgrade Now</span>
              <span id="pr-upgrade-spinner" class="lp-spinner hidden" aria-hidden="true"></span>
            </button>
            <p class="lp-instant-note">Instant Access · Cancel Anytime</p>
          {% endif %}
        </div>
      </div>

    </div>

    {%- comment -%} ── Pro perks in detail ── {%- endcomment -%}
    <div class="lp-perks-section mb-28">
      <div class="lp-section-divider"></div>
      <p class="lp-eyebrow mb-14">Pro Perks in Detail</p>
      <div class="lp-perks-grid">

        <div class="lp-perk reveal" style="transition-delay: 200ms">
          <p class="lp-perk-stat">15%</p>
          <p class="lp-perk-title">Off Every Order</p>
          <p class="lp-perk-body">Applied automatically at checkout, every single time. No codes, no hassle.</p>
        </div>

        <div class="lp-perk reveal" style="transition-delay: 300ms">
          <p class="lp-perk-stat">100</p>
          <p class="lp-perk-title">AI Generations</p>
          <p class="lp-perk-body">Perfectly visualize any piece on yourself with high-fidelity AI virtual try-on.</p>
        </div>

        <div class="lp-perk reveal" style="transition-delay: 400ms">
          <p class="lp-perk-stat">1st</p>
          <p class="lp-perk-title">Priority Access</p>
          <p class="lp-perk-body">Get notified 24 hours before anyone else when limited collections drop.</p>
        </div>

      </div>
    </div>

    {%- comment -%} ── FAQ ── {%- endcomment -%}
    <div class="lp-faq-section reveal" style="transition-delay: 500ms">
      <p class="lp-eyebrow mb-14">Common Questions</p>
      <div class="lp-faq-list">

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">When does the 15% discount apply?</summary>
          <p class="lp-faq-body">It's applied automatically at checkout on every order while your membership is active. You'll see the savings reflected in your subtotal.</p>
        </details>

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">How do image generations work?</summary>
          <p class="lp-faq-body">Each time you use the "Virtual Try-On" feature to generate a preview of a product on your photo, it counts as one generation. Pro members get 100 per month.</p>
        </details>

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">Can I cancel anytime?</summary>
          <p class="lp-faq-body">Absolutely. You can manage your subscription from your account dashboard. Your benefits will remain active until the end of your current billing cycle.</p>
        </details>

        <details class="pr-faq lp-faq-item">
          <summary class="lp-faq-summary">Is there a contract?</summary>
          <p class="lp-faq-body">No contracts or hidden fees. Layered Pro is a simple monthly subscription that you control.</p>
        </details>

      </div>
    </div>

  </div>
</div>

<style>
  /* ── Layered Pricing — Redesign ──────────────────────────────────────────── */
  :root {
    --beige: #F2EBE3;
    --beige-dark: #E8DDD3;
    --beige-mid: #D4C9BE;
    --black: #0E0E0E;
    --off-black: #1A1A1A;
    --white: #FFFFFF;
    --cream: #FAF8F5;
  }

  /* ── Base ───────────────────────────────────────────────────────────────── */
  .lp-page {
    background-color: var(--cream);
    color: var(--black);
    font-family: 'Inter', system-ui, sans-serif;
  }

  .lp-bg-accent {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 55% 45% at 80% 15%, rgba(242,235,227,0.55) 0%, transparent 65%),
      radial-gradient(ellipse 40% 50% at 10% 85%, rgba(242,235,227,0.3) 0%, transparent 60%);
    z-index: 0;
  }

  /* ── Navigation ─────────────────────────────────────────────────────────── */
  .lp-nav {
    background: rgba(250, 248, 245, 0.92);
    border-bottom: 1px solid rgba(14, 14, 14, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: all 0.3s ease;
  }

  .lp-logo {
    color: var(--black);
    font-weight: 500;
    letter-spacing: -0.04em;
    text-decoration: none;
  }

  .lp-logo-mark {
    width: 34px;
    height: 34px;
    background: var(--black);
    color: var(--white);
    border-radius: 50%;
    font-family: 'Fraunces', serif;
  }

  .lp-nav-link {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: rgba(14, 14, 14, 0.38);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .lp-nav-link:hover { color: var(--black); }
  .lp-nav-link--active {
    color: var(--black);
    border-bottom: 1.5px solid var(--black);
    padding-bottom: 2px;
  }

  .lp-hamburger {
    background: none;
    border: none;
    color: var(--black);
    cursor: pointer;
    padding: 6px;
  }

  .lp-mobile-menu {
    background: var(--cream);
    border-top: 1px solid rgba(14, 14, 14, 0.08);
  }

  .lp-mobile-link {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    color: rgba(14, 14, 14, 0.45);
    text-decoration: none;
    transition: color 0.2s;
    font-style: italic;
  }

  .lp-mobile-link:hover,
  .lp-mobile-link--active { color: var(--black); }

  /* ── Hero ───────────────────────────────────────────────────────────────── */
  .lp-pricing-hero { max-width: 700px; }

  .lp-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(14, 14, 14, 0.35);
    font-weight: 600;
    display: block;
  }

  .lp-display {
    font-family: 'Fraunces', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--black);
    font-weight: 400;
    margin: 0;
  }

  .lp-display--italic {
    font-style: italic;
    color: rgba(14, 14, 14, 0.22);
  }

  .lp-hero-rule {
    width: 56px;
    height: 1px;
    background: var(--beige-mid);
    margin-top: 2rem;
  }

  .lp-hero-body {
    font-size: 1.05rem;
    color: rgba(14, 14, 14, 0.5);
    line-height: 1.7;
    max-width: 400px;
  }

  /* ── Plans grid ─────────────────────────────────────────────────────────── */
  .lp-plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }

  @media (min-width: 768px) {
    .lp-plans-grid { grid-template-columns: 1fr 1fr; }
  }

  .lp-plan {
    padding: 3rem 3.5rem;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .lp-plan--free {
    background: var(--white);
    border: 1px solid rgba(14, 14, 14, 0.08);
    transition: border-color 0.3s ease;
  }

  .lp-plan--free:hover { border-color: rgba(14, 14, 14, 0.2); }

  .lp-plan--pro {
    background: var(--black);
    color: var(--white);
    overflow: hidden;
  }

  .lp-plan--pro::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(242,235,227,0.06) 100%);
    pointer-events: none;
  }

  .lp-plan-badge {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: var(--beige);
    color: var(--black);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-weight: 700;
    padding: 6px 14px;
  }

  .lp-plan-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .lp-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: rgba(14, 14, 14, 0.35);
  }

  .lp-label--light { color: rgba(255,255,255,0.35); }

  .lp-plan-name {
    font-family: 'Fraunces', serif;
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--black);
    font-style: italic;
    margin-top: 4px;
  }

  .lp-plan-name--pro { color: var(--white); }

  .lp-price {
    font-family: 'Fraunces', serif;
    font-size: 3rem;
    font-weight: 400;
    color: var(--black);
    letter-spacing: -0.03em;
  }

  .lp-price--pro { color: var(--white); }

  .lp-price-note {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: rgba(14, 14, 14, 0.3);
    margin-top: 4px;
  }

  .lp-price-note--pro { color: rgba(255,255,255,0.3); }

  .lp-plan-desc {
    font-size: 0.875rem;
    color: rgba(14, 14, 14, 0.48);
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .lp-plan-desc--pro { color: rgba(255,255,255,0.48); }

  /* ── Feature list ───────────────────────────────────────────────────────── */
  .lp-features {
    list-style: none;
    margin: 0 0 2.5rem 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .lp-feature {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 0.875rem;
  }

  .lp-feature--yes { color: rgba(14, 14, 14, 0.72); font-weight: 500; }
  .lp-feature--no  { color: rgba(14, 14, 14, 0.22); text-decoration: line-through; text-decoration-color: rgba(14,14,14,0.1); }
  .lp-feature--pro-item { color: rgba(255,255,255,0.75); font-weight: 500; }

  .lp-feature-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .lp-feature-icon--yes {
    border: 1px solid rgba(14,14,14,0.18);
    color: var(--black);
  }

  .lp-feature-icon--no {
    border: 1px solid rgba(14,14,14,0.07);
    color: rgba(14,14,14,0.2);
  }

  .lp-feature-icon--pro {
    background: var(--beige);
    color: var(--black);
  }

  /* ── CTA area ───────────────────────────────────────────────────────────── */
  .lp-plan-cta { margin-top: auto; }

  .lp-plan-active {
    width: 100%;
    padding: 14px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: rgba(14,14,14,0.3);
    border: 1px solid rgba(14,14,14,0.1);
  }

  .lp-plan-active--pro {
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.4);
    border-color: rgba(255,255,255,0.1);
  }

  .lp-btn-outline--dark {
    display: inline-block;
    padding: 14px 24px;
    border: 1.5px solid rgba(14,14,14,0.25);
    color: var(--black);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
    text-align: center;
    background: transparent;
  }

  .lp-btn-outline--dark:hover {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  .lp-btn-primary-inv {
    display: inline-block;
    padding: 15px 24px;
    background: var(--beige);
    color: var(--black);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s;
    text-align: center;
  }

  .lp-btn-primary-inv:hover { opacity: 0.88; transform: translateY(-1px); }
  .lp-btn-primary-inv:active { transform: scale(0.98); }

  .lp-instant-note {
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: rgba(255,255,255,0.25);
    margin-top: 1.25rem;
  }

  /* ── Pro perks section ──────────────────────────────────────────────────── */
  .lp-section-divider {
    width: 100%;
    height: 1px;
    background: rgba(14,14,14,0.08);
    margin-bottom: 3.5rem;
  }

  .lp-perks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2px;
  }

  @media (min-width: 768px) {
    .lp-perks-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .lp-perk {
    background: var(--white);
    border: 1px solid rgba(14,14,14,0.07);
    padding: 2.5rem 2.75rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .lp-perk:hover {
    border-color: rgba(14,14,14,0.15);
    box-shadow: 0 6px 32px -8px rgba(14,14,14,0.08);
  }

  .lp-perk-stat {
    font-family: 'Fraunces', serif;
    font-size: 3.5rem;
    font-weight: 400;
    font-style: italic;
    color: var(--black);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .lp-perk-title {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: rgba(14,14,14,0.4);
    margin-bottom: 0.75rem;
  }

  .lp-perk-body {
    font-size: 0.875rem;
    color: rgba(14,14,14,0.5);
    line-height: 1.7;
  }

  /* ── FAQ ────────────────────────────────────────────────────────────────── */
  .lp-faq-section { max-width: 640px; }

  .lp-faq-list {
    border-top: 1px solid rgba(14,14,14,0.08);
  }

  .lp-faq-item {
    border-bottom: 1px solid rgba(14,14,14,0.08);
  }

  .lp-faq-summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
    padding: 1.5rem 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(14,14,14,0.7);
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .lp-faq-summary::-webkit-details-marker { display: none; }
  .lp-faq-summary:hover { color: var(--black); }

  .lp-faq-summary::after {
    content: '+';
    font-size: 1.4rem;
    font-weight: 200;
    color: rgba(14,14,14,0.25);
    flex-shrink: 0;
    transition: transform 0.3s ease;
    font-family: 'Fraunces', serif;
    font-style: italic;
  }

  .lp-faq-item[open] .lp-faq-summary::after {
    content: '−';
    transform: rotate(180deg);
  }

  .lp-faq-body {
    padding-bottom: 1.5rem;
    font-size: 0.875rem;
    color: rgba(14,14,14,0.45);
    line-height: 1.75;
  }

  /* ── Scroll reveal ──────────────────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(.22,1,.36,1), transform 0.8s cubic-bezier(.22,1,.36,1);
  }
  .reveal.active { opacity: 1; transform: translateY(0); }

  /* ── Arbitrary Tailwind fallbacks ───────────────────────────────────────── */
  .text-\[10px\] { font-size: 10px; }
  .text-\[9px\]  { font-size: 9px; }
  .text-\[8px\]  { font-size: 8px; }
  .tracking-\[0\.2em\] { letter-spacing: .2em; }
  .tracking-\[0\.3em\] { letter-spacing: .3em; }
  .tracking-\[0\.4em\] { letter-spacing: .4em; }
  .leading-\[0\.9\]    { line-height: .9; }
  .backdrop-blur-sm  { -webkit-backdrop-filter: blur(4px);  backdrop-filter: blur(4px); }
  .backdrop-blur-xl  { -webkit-backdrop-filter: blur(24px); backdrop-filter: blur(24px); }
  .backdrop-blur-2xl { -webkit-backdrop-filter: blur(40px); backdrop-filter: blur(40px); }
  .hover\:scale-\[1\.02\]:hover   { transform: scale(1.02); }
  .active\:scale-\[0\.98\]:active { transform: scale(.98); }

  /* ── Legacy FAQ (kept for Shopify Liquid class) ── */
  .pr-faq summary { cursor: pointer; list-style: none; }
  .pr-faq summary::-webkit-details-marker { display: none; }

  /* ── Upgrade button loading state ─────────────────────────────────────── */
  #pr-upgrade-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
  }

  .lp-spinner {
    display: inline-block;
    width: 13px;
    height: 13px;
    border: 1.8px solid rgba(14, 14, 14, 0.2);
    border-top-color: var(--black);
    border-radius: 50%;
    animation: lp-spin 0.65s linear infinite;
    vertical-align: middle;
    margin-left: 8px;
  }

  @keyframes lp-spin { to { transform: rotate(360deg); } }
</style>

<script>
(function() {
  /* ── Mobile menu ─────────────────────────────────────────────────────── */
  const toggle = document.getElementById('pr-menu-toggle');
  const menu   = document.getElementById('pr-mobile-menu');
  if (toggle && menu) toggle.addEventListener('click', () => menu.classList.toggle('hidden'));

  /* ── Scroll reveal ───────────────────────────────────────────────────── */
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  /* ── Pro upgrade → Shopify native checkout ───────────────────────────
   *
   *  Mirrors cartStore.ts exactly:
   *   1. Call Storefront API cartCreate with the Pro variant (qty 1)
   *   2. Append ?channel=online_store  (matches formatCheckoutUrl helper)
   *   3. Hard-navigate to the returned checkoutUrl
   *
   *  The Storefront domain + token are read from window.__layered_shopify,
   *  the same config object that lib/shopify.ts consumes in the React SPA.
   *  If that object is absent we fall back to the legacy /cart/ route so
   *  the button is never left completely broken.
   *
   *  Product:  layered-pro-plan  (type: Service)
   *  Variant:  server-rendered by Liquid into data-variant-id
   * ────────────────────────────────────────────────────────────────────── */

  const CART_CREATE_MUTATION = `
    mutation cartCreate($input: CartInput!) {
      cartCreate(input: $input) {
        cart { id checkoutUrl }
        userErrors { field message }
      }
    }
  `;

  function formatCheckoutUrl(u) {
    try {
      const url = new URL(u);
      url.searchParams.set('channel', 'online_store');
      return url.toString();
    } catch { return u; }
  }

  async function storefrontRequest(query, variables) {
    /* Read config injected by the headless theme — same source as lib/shopify.ts */
    const cfg     = window.__layered_shopify || {};
    const domain  = cfg.domain  || (window.Shopify && window.Shopify.shop) || location.hostname;
    const token   = cfg.storefrontAccessToken || cfg.token || '';
    const version = cfg.apiVersion || '2024-07';

    const res = await fetch(`https://${domain}/api/${version}/graphql.json`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Storefront-Access-Token': token,
      },
      body: JSON.stringify({ query, variables }),
    });
    if (!res.ok) throw new Error('Storefront API ' + res.status);
    return res.json();
  }

  async function createProCheckout(variantId) {
    /* Liquid renders a numeric ID; Storefront API needs the GID format */
    const gid = variantId.startsWith('gid://')
      ? variantId
      : 'gid://shopify/ProductVariant/' + variantId;

    const data = await storefrontRequest(CART_CREATE_MUTATION, {
      input: { lines: [{ quantity: 1, merchandiseId: gid }] }
    });

    const errs = (data && data.data && data.data.cartCreate && data.data.cartCreate.userErrors) || [];
    if (errs.length) { console.error('[Layered] cartCreate errors:', errs); return null; }

    const checkoutUrl = data && data.data && data.data.cartCreate && data.data.cartCreate.cart && data.data.cartCreate.cart.checkoutUrl;
    return checkoutUrl ? formatCheckoutUrl(checkoutUrl) : null;
  }

  const upgradeBtn = document.getElementById('pr-upgrade-btn');
  if (upgradeBtn) {
    upgradeBtn.addEventListener('click', async function() {
      const variantId = upgradeBtn.dataset.variantId;

      /* Safety: no variant means the product is unavailable server-side */
      if (!variantId) { window.location.href = '/collections/all'; return; }

      /* Show loading state */
      var label   = document.getElementById('pr-upgrade-label');
      var spinner = document.getElementById('pr-upgrade-spinner');
      upgradeBtn.disabled = true;
      if (label)   label.textContent = 'Preparing checkout…';
      if (spinner) spinner.classList.remove('hidden');

      try {
        var checkoutUrl = await createProCheckout(variantId);
        /* Navigate to native Shopify checkout */
        window.location.href = checkoutUrl || ('/cart/' + variantId + ':1/checkout');
      } catch (err) {
        console.error('[Layered] Checkout creation failed:', err);
        /* Graceful fallback — legacy route still completes the purchase */
        window.location.href = '/cart/' + variantId + ':1/checkout';
      }
    });
  }
})();
</script>
