<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <style>
    body {
      font-family: 'Inter', system-ui, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      background: #F5F2EC;
      color: #1C1C1C;
    }
    .container {
      text-align: center;
      max-width: 400px;
      padding: 2rem;
    }
    h1 {
      font-family: 'Fraunces', serif;
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }
    p { color: #666; font-size: 0.875rem; margin-bottom: 1.5rem; }
    form { display: flex; gap: 0.5rem; }
    input {
      flex: 1;
      padding: 0.75rem 1rem;
      border: 1px solid #D9D9D9;
      background: transparent;
      font-size: 0.875rem;
    }
    button {
      padding: 0.75rem 1.5rem;
      background: #1C1C1C;
      color: #F5F2EC;
      border: none;
      font-size: 0.875rem;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>{{ shop.name }}</h1>
    <p>We're getting things ready. Enter the password to continue.</p>
    {% form 'storefront_password' %}
      <input type="password" name="password" placeholder="Password" />
      <button type="submit">Enter</button>
    {% endform %}
  </div>
</body>
</html>
