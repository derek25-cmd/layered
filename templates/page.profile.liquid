{% comment %} Profile — uses SPA design tokens from layered-app.css {% endcomment %}

{%- comment -%} ── Minimal site nav for native pages ── {%- endcomment -%}
<header class="lp-nav fixed top-0 inset-x-0 z-50">
  <div class="lp-nav-inner container max-w-7xl mx-auto px-8 h-[72px] flex items-center justify-between">
    <a href="/" class="font-display text-xl tracking-tighter lp-logo group flex items-center gap-3">
      <span class="lp-logo-mark w-9 h-9 flex items-center justify-center font-bold text-sm transition-transform duration-500 group-hover:rotate-12">L</span>
      Layered
    </a>
    <nav class="hidden md:flex items-center gap-10">
      <a href="/collections/all" class="lp-nav-link">Shop</a>
      <a href="/outfits" class="lp-nav-link">Outfits</a>
      <a href="/ai-assistant" class="lp-nav-link">AI Stylist</a>
      <a href="/pages/profile" class="lp-nav-link lp-nav-link--active">Profile</a>
      <a href="/pages/pricing" class="lp-nav-link">Pricing</a>
      {% if customer %}
        <a href="/account" class="lp-nav-link">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="lp-nav-link">Sign in</a>
      {% endif %}
    </nav>
    <button id="pf-menu-toggle" class="lp-hamburger md:hidden" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M3 8h18M3 16h18"/></svg>
    </button>
  </div>
  <div id="pf-mobile-menu" class="lp-mobile-menu hidden md:hidden">
    <div class="container max-w-7xl mx-auto px-8 py-12 flex flex-col gap-7">
      <a href="/collections/all" class="lp-mobile-link">Shop</a>
      <a href="/outfits" class="lp-mobile-link">Outfits</a>
      <a href="/ai-assistant" class="lp-mobile-link">AI Stylist</a>
      <a href="/pages/profile" class="lp-mobile-link lp-mobile-link--active">Profile</a>
      <a href="/pages/pricing" class="lp-mobile-link">Pricing</a>
      {% if customer %}
        <a href="/account" class="lp-mobile-link">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="lp-mobile-link">Sign in</a>
      {% endif %}
    </div>
  </div>
</header>

<div class="lp-page min-h-screen pt-[72px]">
  <div class="container max-w-7xl mx-auto px-8 py-24">

    {% if customer %}

      {%- comment -%} ── Page heading ── {%- endcomment -%}
      <div class="lp-hero mb-24 reveal">
        <p class="lp-eyebrow mb-5">Dashboard</p>
        <h1 class="lp-display">{{ customer.first_name }}<span class="lp-display--italic">'s space.</span></h1>
        <div class="lp-hero-rule"></div>
      </div>

      <div class="grid lg:grid-cols-3 gap-14">

        {%- comment -%} ── Left column ── {%- endcomment -%}
        <div class="lg:col-span-2 space-y-10">

          {%- comment -%} Usage tracker {%- endcomment -%}
          {% if customer.tags contains 'Pro Member' %}
            <div class="lp-card reveal">
              <div class="lp-card-header">
                <div>
                  <p class="lp-label mb-1">Pro Membership Perk</p>
                  <p class="lp-card-title">AI Virtual Try-On Generations</p>
                </div>
                <div class="lp-usage-count text-right">
                  <span class="lp-stat-number">42</span>
                  <span class="lp-stat-denom">/ 100</span>
                </div>
              </div>
              <div class="lp-progress-track">
                <div class="lp-progress-fill" style="width: 42%"></div>
              </div>
              <div class="lp-progress-labels">
                <span>Usage this month</span>
                <span>58 Remaining</span>
              </div>
            </div>
          {% endif %}

          {%- comment -%} Account details card {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:80ms">
            <div class="lp-card-header mb-10">
              <p class="lp-label">Account Intelligence</p>
              <a href="/account" class="lp-text-link">Modify Account</a>
            </div>
            <div class="grid sm:grid-cols-2 gap-8">
              <div class="lp-field">
                <p class="lp-field-label">Legal Identity</p>
                <p class="lp-field-value">{{ customer.name | default: '—' }}</p>
              </div>
              <div class="lp-field">
                <p class="lp-field-label">Digital Address</p>
                <p class="lp-field-value truncate">{{ customer.email }}</p>
              </div>
              <div class="lp-field">
                <p class="lp-field-label">Member Since</p>
                <p class="lp-field-value">{{ customer.created_at | date: "%B %Y" }}</p>
              </div>
              <div class="lp-field">
                <p class="lp-field-label">History</p>
                <p class="lp-field-value">{{ customer.orders.size }} Orders</p>
              </div>
            </div>
          </div>

          {%- comment -%} Style preferences {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:160ms">
            <p class="lp-label mb-6">Style Algorithm</p>
            <p class="lp-body-muted mb-8">Select your areas of focus. Our engine uses these to curate your feed.</p>
            <div id="pf-prefs" class="flex flex-wrap gap-3 mb-10">
              {%- assign categories = 'Tops,Bottoms,Outerwear,Shoes,Accessories' | split: ',' -%}
              {% for cat in categories %}
                <button
                  data-cat="{{ cat }}"
                  class="pf-pref-btn lp-pref-btn"
                >{{ cat }}</button>
              {% endfor %}
            </div>
            <button id="pf-save-prefs" class="lp-btn-primary">
              Sync Preferences
            </button>
            <p id="pf-prefs-saved" class="lp-saved-msg mt-4 hidden">Preferences synchronized.</p>
          </div>

          {%- comment -%} Saved outfits {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:240ms">
            <div class="lp-card-header mb-10">
              <p class="lp-label">Saved Blueprints</p>
              <a href="/outfits/build" class="lp-text-link">New Build →</a>
            </div>
            <div id="pf-outfits-list">
              <p class="lp-body-muted">Initialising archives…</p>
            </div>
          </div>

        </div>

        {%- comment -%} ── Right sidebar ── {%- endcomment -%}
        <div class="space-y-8">

          {%- comment -%} Identity card {%- endcomment -%}
          <div class="lp-card lp-card--identity text-center reveal" style="transition-delay:120ms">
            <div class="lp-avatar mx-auto mb-6">
              {{ customer.first_name | slice: 0 | upcase }}
            </div>
            <p class="font-display text-2xl mb-1 lp-identity-name">{{ customer.name }}</p>
            <p class="lp-identity-email mb-8">{{ customer.email }}</p>
            
            {% if customer.tags contains 'Pro Member' %}
              <div class="lp-badge-pro inline-flex items-center gap-2 mb-3">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                Pro Member
              </div>
              <p class="lp-discount-note">15% Discount Active</p>
              <a href="mailto:{{ shop.email }}?subject=Cancel+Layered+Pro+Membership&body=Hi%2C+I+would+like+to+cancel+my+Layered+Pro+membership.+My+account+email+is+{{ customer.email | url_encode }}." class="lp-cancel-link">Cancel Membership</a>
            {% else %}
              <a href="/pages/pricing" class="lp-btn-outline w-full block">
                Upgrade to Pro
              </a>
              <p class="lp-discount-note mt-3">Unlock 15% discount</p>
            {% endif %}
          </div>

          {%- comment -%} Quick links {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:200ms">
            <p class="lp-label mb-8">Navigation</p>
            <ul class="lp-nav-list space-y-1">
              <li><a href="/account" class="lp-nav-item group">Order Archive <span class="lp-nav-arrow">→</span></a></li>
              <li><a href="{{ routes.account_addresses_url }}" class="lp-nav-item group">Addresses <span class="lp-nav-arrow">→</span></a></li>
              <li><a href="/pages/pricing" class="lp-nav-item group">Membership <span class="lp-nav-arrow">→</span></a></li>
              <li><a href="/collections/all" class="lp-nav-item group">Marketplace <span class="lp-nav-arrow">→</span></a></li>
              <li class="lp-nav-divider"><a href="{{ routes.account_logout_url }}" class="lp-nav-item lp-nav-item--danger">Terminate Session</a></li>
            </ul>
          </div>

        </div>
      </div>

    {% else %}

      <div class="lp-auth-gate reveal">
        <div class="lp-auth-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h2 class="font-display text-4xl mb-5 lp-auth-title">Authorisation Required</h2>
        <p class="lp-auth-body mb-12">Your profile and style algorithm are only accessible within an active session.</p>
        <a href="{{ routes.account_login_url }}?return_to=/pages/profile" class="lp-btn-primary lp-btn-primary--large">
          Sign In
        </a>
      </div>

    {% endif %}

  </div>
</div>

{%- comment -%} ── Pro Activation Dialog ── {%- endcomment -%}
<div id="lp-pro-dialog" class="lp-dialog-overlay" role="dialog" aria-modal="true" aria-labelledby="lp-dialog-title">
  <div class="lp-dialog">
    <button class="lp-dialog-close" id="lp-dialog-close" aria-label="Close">✕</button>

    <div id="lp-dialog-success">
      <div class="lp-dialog-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" fill="#0E0E0E" opacity="0.55"/></svg>
      </div>
      <p class="lp-eyebrow mb-3">Membership Activated</p>
      <h2 id="lp-dialog-title" class="lp-dialog-heading">Welcome to Layered Pro<span class="lp-dialog-heading--italic">.</span></h2>
      <div class="lp-dialog-rule"></div>
      <ul class="lp-dialog-perks">
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>15% off every order, applied automatically</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>100 AI Virtual Try-On generations per month</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>Free shipping on every order</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>24-hour early access to new drops</li>
      </ul>
      <a href="/collections/all" class="lp-btn-primary lp-btn-primary--large lp-dialog-cta">Shop with Pro</a>
    </div>

    <div id="lp-dialog-activating" style="display:none">
      <div class="lp-dialog-icon lp-dialog-icon--pulse">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      </div>
      <p class="lp-eyebrow mb-3">One moment</p>
      <h2 class="lp-dialog-heading">Activating your membership<span class="lp-dialog-heading--italic">.</span></h2>
      <div class="lp-dialog-rule"></div>
      <p class="lp-body-muted" style="font-size:0.9rem">Your Pro membership is being confirmed. This page will refresh automatically in a few seconds.</p>
    </div>
  </div>
</div>

<style>
  /* ── Layered Profile — Redesign ──────────────────────────────────────────── */
  :root {
    --beige: #F2EBE3;
    --beige-dark: #E8DDD3;
    --beige-mid: #D4C9BE;
    --black: #0E0E0E;
    --off-black: #1A1A1A;
    --soft-black: #2C2C2C;
    --white: #FFFFFF;
    --cream: #FAF8F5;
  }

  /* ── Base page ──────────────────────────────────────────────────────────── */
  .lp-page {
    background-color: var(--cream);
    color: var(--black);
    font-family: 'Inter', system-ui, sans-serif;
    min-height: 100vh;
  }

  /* ── Navigation ─────────────────────────────────────────────────────────── */
  .lp-nav {
    background: rgba(250, 248, 245, 0.92);
    border-bottom: 1px solid rgba(14, 14, 14, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: all 0.3s ease;
  }

  .lp-logo {
    color: var(--black);
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .lp-logo-mark {
    width: 34px;
    height: 34px;
    background: var(--black);
    color: var(--white);
    border-radius: 50%;
    font-family: 'Fraunces', serif;
  }

  .lp-nav-link {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: rgba(14, 14, 14, 0.38);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .lp-nav-link:hover { color: var(--black); }
  .lp-nav-link--active {
    color: var(--black);
    border-bottom: 1.5px solid var(--black);
    padding-bottom: 2px;
  }

  .lp-hamburger {
    background: none;
    border: none;
    color: var(--black);
    cursor: pointer;
    padding: 6px;
  }

  .lp-mobile-menu {
    background: var(--cream);
    border-top: 1px solid rgba(14, 14, 14, 0.08);
  }

  .lp-mobile-link {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    color: rgba(14, 14, 14, 0.45);
    text-decoration: none;
    transition: color 0.2s;
    font-style: italic;
  }

  .lp-mobile-link:hover,
  .lp-mobile-link--active { color: var(--black); }

  /* ── Hero Heading ───────────────────────────────────────────────────────── */
  .lp-hero { }

  .lp-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: rgba(14, 14, 14, 0.35);
    font-weight: 600;
  }

  .lp-display {
    font-family: 'Fraunces', serif;
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--black);
    font-weight: 400;
    margin: 0;
  }

  .lp-display--italic {
    font-style: italic;
    color: rgba(14, 14, 14, 0.22);
  }

  .lp-hero-rule {
    width: 60px;
    height: 1px;
    background: var(--beige-mid);
    margin-top: 2rem;
  }

  /* ── Cards ──────────────────────────────────────────────────────────────── */
  .lp-card {
    background: var(--white);
    border: 1px solid rgba(14, 14, 14, 0.07);
    padding: 2.5rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .lp-card:hover {
    border-color: rgba(14, 14, 14, 0.14);
    box-shadow: 0 8px 40px -12px rgba(14, 14, 14, 0.1);
  }

  .lp-card--identity {
    background: var(--beige);
    border-color: transparent;
  }

  .lp-card--identity:hover {
    border-color: var(--beige-mid);
    box-shadow: 0 8px 32px -8px rgba(14, 14, 14, 0.08);
  }

  .lp-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .lp-card-title {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--black);
    margin-top: 2px;
  }

  /* ── Labels & text styles ───────────────────────────────────────────────── */
  .lp-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: rgba(14, 14, 14, 0.35);
  }

  .lp-text-link {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: rgba(14, 14, 14, 0.4);
    text-decoration: none;
    border-bottom: 1px solid rgba(14, 14, 14, 0.12);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .lp-text-link:hover {
    color: var(--black);
    border-color: var(--black);
  }

  .lp-body-muted {
    font-size: 0.875rem;
    color: rgba(14, 14, 14, 0.45);
    line-height: 1.7;
  }

  /* ── Fields ─────────────────────────────────────────────────────────────── */
  .lp-field { }

  .lp-field-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: rgba(14, 14, 14, 0.28);
    margin-bottom: 6px;
  }

  .lp-field-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--black);
    letter-spacing: -0.01em;
  }

  /* ── Progress bar ───────────────────────────────────────────────────────── */
  .lp-stat-number {
    font-family: 'Fraunces', serif;
    font-size: 2.25rem;
    font-weight: 400;
    color: var(--black);
  }

  .lp-stat-denom {
    font-size: 0.75rem;
    color: rgba(14, 14, 14, 0.3);
    margin-left: 2px;
  }

  .lp-progress-track {
    height: 2px;
    background: rgba(14, 14, 14, 0.07);
    width: 100%;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  .lp-progress-fill {
    height: 100%;
    background: var(--black);
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lp-progress-labels {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: rgba(14, 14, 14, 0.3);
  }

  /* ── Preferences buttons ────────────────────────────────────────────────── */
  .lp-pref-btn {
    padding: 10px 20px;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    border: 1px solid rgba(14, 14, 14, 0.15);
    background: transparent;
    color: rgba(14, 14, 14, 0.5);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lp-pref-btn:hover {
    border-color: var(--black);
    color: var(--black);
  }

  .lp-pref-btn.active,
  .lp-pref-btn.bg-white {
    background: var(--black) !important;
    color: var(--white) !important;
    border-color: var(--black) !important;
  }

  /* ── Buttons ────────────────────────────────────────────────────────────── */
  .lp-btn-primary {
    display: inline-block;
    padding: 14px 32px;
    background: var(--black);
    color: var(--white);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s ease, opacity 0.2s;
    text-align: center;
  }

  .lp-btn-primary:hover { opacity: 0.85; transform: translateY(-1px); }
  .lp-btn-primary:active { transform: scale(0.98); }

  .lp-btn-primary--large {
    padding: 18px 56px;
    font-size: 11px;
  }

  .lp-btn-outline {
    display: inline-block;
    padding: 13px 24px;
    background: transparent;
    border: 1.5px solid var(--black);
    color: var(--black);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease;
    text-align: center;
  }

  .lp-btn-outline:hover {
    background: var(--black);
    color: var(--white);
  }

  .lp-saved-msg {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    color: #2a7a4b;
  }

  /* ── Identity card ──────────────────────────────────────────────────────── */
  .lp-avatar {
    width: 72px;
    height: 72px;
    background: var(--black);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Fraunces', serif;
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
  }

  .lp-identity-name {
    color: var(--black);
    letter-spacing: -0.02em;
  }

  .lp-identity-email {
    font-size: 10px;
    text-transform: none;
    color: rgba(14, 14, 14, 0.42);
    letter-spacing: 0;
    font-size: 0.8rem;
  }

  .lp-badge-pro {
    background: var(--black);
    color: var(--white);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    padding: 8px 16px;
  }

  .lp-discount-note {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(14, 14, 14, 0.35);
    font-weight: 600;
    margin-top: 10px;
  }

  /* ── Nav list ───────────────────────────────────────────────────────────── */
  .lp-nav-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 0;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: rgba(14, 14, 14, 0.4);
    text-decoration: none;
    border-bottom: 1px solid rgba(14, 14, 14, 0.06);
    transition: color 0.2s ease;
  }

  .lp-nav-item:last-child { border-bottom: none; }
  .lp-nav-item:hover { color: var(--black); }

  .lp-nav-arrow {
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  .lp-nav-item:hover .lp-nav-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  .lp-nav-divider {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid rgba(14, 14, 14, 0.07);
  }

  .lp-nav-item--danger {
    color: rgba(185, 40, 40, 0.5);
    border-bottom: none;
  }

  .lp-nav-item--danger:hover { color: rgb(185, 40, 40); }

  /* ── Auth gate ──────────────────────────────────────────────────────────── */
  .lp-auth-gate {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
    padding: 6rem 3rem;
    background: var(--white);
    border: 1px solid rgba(14, 14, 14, 0.07);
  }

  .lp-auth-icon {
    width: 64px;
    height: 64px;
    background: var(--beige);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.75rem;
    color: rgba(14, 14, 14, 0.45);
  }

  .lp-auth-title { color: var(--black); letter-spacing: -0.02em; }
  .lp-auth-body {
    font-size: 0.9rem;
    color: rgba(14, 14, 14, 0.45);
    line-height: 1.7;
    max-width: 300px;
    margin: 0 auto;
  }

  /* ── Outfit grid (injected via JS) ─────────────────────────────────────── */
  .lp-outfit-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  @media (min-width: 640px) { .lp-outfit-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 768px) { .lp-outfit-grid { grid-template-columns: repeat(4, 1fr); } }

  .lp-outfit-card-image {
    aspect-ratio: 3/4;
    background: var(--beige);
    margin-bottom: 10px;
    overflow: hidden;
    border: 1px solid rgba(14,14,14,0.06);
  }

  .lp-outfit-card-image img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .lp-outfit-card:hover .lp-outfit-card-image img { transform: scale(1.06); }

  .lp-outfit-label {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    color: rgba(14,14,14,0.25);
    margin-bottom: 3px;
  }

  .lp-outfit-title {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: var(--black);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lp-reconfigure-btn {
    display: inline-block;
    margin-top: 2rem;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: rgba(14,14,14,0.4);
    text-decoration: none;
    border: 1px solid rgba(14,14,14,0.12);
    padding: 12px 24px;
    transition: all 0.2s;
  }

  .lp-reconfigure-btn:hover {
    color: var(--black);
    border-color: var(--black);
  }

  /* ── Scroll reveal ──────────────────────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(.22,1,.36,1), transform 0.8s cubic-bezier(.22,1,.36,1);
  }
  .reveal.active { opacity: 1; transform: translateY(0); }

  /* ── Arbitrary Tailwind fallbacks ───────────────────────────────────────── */
  .text-\[10px\] { font-size: 10px; }
  .text-\[9px\]  { font-size: 9px; }
  .text-\[8px\]  { font-size: 8px; }
  .tracking-\[0\.2em\] { letter-spacing: .2em; }
  .tracking-\[0\.3em\] { letter-spacing: .3em; }
  .tracking-\[0\.4em\] { letter-spacing: .4em; }
  .leading-\[0\.9\]    { line-height: .9; }
  .w-\[42\%\]          { width: 42%; }
  .aspect-\[3\/4\]     { aspect-ratio: 3/4; }
  .backdrop-blur-sm  { -webkit-backdrop-filter: blur(4px);  backdrop-filter: blur(4px); }
  .backdrop-blur-xl  { -webkit-backdrop-filter: blur(24px); backdrop-filter: blur(24px); }
  .backdrop-blur-2xl { -webkit-backdrop-filter: blur(40px); backdrop-filter: blur(40px); }
  .hover\:scale-105:hover  { transform: scale(1.05); }
  .active\:scale-95:active { transform: scale(.95); }
  .group\/item:hover .group-hover\/item\:scale-110 { transform: scale(1.10); }

  /* ── Cancel link ─────────────────────────────────────────────────────────── */
  .lp-cancel-link {
    display: block;
    margin-top: 0.875rem;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    color: rgba(14,14,14,0.28);
    text-decoration: none;
    transition: color 0.2s;
  }
  .lp-cancel-link:hover { color: rgba(14,14,14,0.6); }

  /* ── Pro activation dialog ──────────────────────────────────────────────── */
  .lp-dialog-overlay {
    position: fixed;
    inset: 0;
    background: rgba(14,14,14,0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .lp-dialog-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .lp-dialog {
    background: var(--cream);
    max-width: 460px;
    width: 100%;
    padding: 3rem 2.75rem 2.5rem;
    position: relative;
    transform: translateY(18px) scale(0.98);
    transition: transform 0.4s cubic-bezier(.22,1,.36,1);
    border: 1px solid rgba(14,14,14,0.08);
  }
  .lp-dialog-overlay.active .lp-dialog {
    transform: translateY(0) scale(1);
  }
  .lp-dialog-close {
    position: absolute;
    top: 1.1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1rem;
    color: rgba(14,14,14,0.3);
    cursor: pointer;
    padding: 4px 6px;
    line-height: 1;
    transition: color 0.2s;
    font-family: inherit;
  }
  .lp-dialog-close:hover { color: var(--black); }
  .lp-dialog-icon {
    width: 52px;
    height: 52px;
    background: var(--beige);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .lp-dialog-icon--pulse { animation: lp-dialog-pulse 1.8s ease-in-out infinite; }
  @keyframes lp-dialog-pulse { 0%,100% { opacity:1; } 50% { opacity:0.45; } }
  .lp-dialog-heading {
    font-family: 'Fraunces', serif;
    font-size: 1.9rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--black);
    margin: 0;
  }
  .lp-dialog-heading--italic { font-style: italic; color: rgba(14,14,14,0.22); }
  .lp-dialog-rule {
    width: 40px;
    height: 1px;
    background: var(--beige-mid);
    margin: 1.4rem 0;
  }
  .lp-dialog-perks {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .lp-dialog-perk {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.875rem;
    color: rgba(14,14,14,0.6);
  }
  .lp-dialog-perk-dot {
    width: 5px;
    height: 5px;
    background: var(--beige-mid);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .lp-dialog-cta {
    display: block;
    text-align: center;
    text-decoration: none;
  }
</style>

<script>
(function() {
  // Mobile menu toggle
  const toggle = document.getElementById('pf-menu-toggle');
  const menu   = document.getElementById('pf-mobile-menu');
  if (toggle && menu) toggle.addEventListener('click', () => menu.classList.toggle('hidden'));

  // ── Pro activation dialog ─────────────────────────────────────────────
  (function() {
    var IS_PRO = {% if customer and customer.tags contains 'Pro Member' %}true{% else %}false{% endif %};
    var overlay  = document.getElementById('lp-pro-dialog');
    var closeBtn = document.getElementById('lp-dialog-close');

    function openDialog(mode) {
      if (!overlay) return;
      document.getElementById('lp-dialog-success').style.display    = mode === 'success'    ? '' : 'none';
      document.getElementById('lp-dialog-activating').style.display = mode === 'activating' ? '' : 'none';
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeDialog() {
      if (!overlay) return;
      overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    if (closeBtn) closeBtn.addEventListener('click', closeDialog);
    if (overlay)  overlay.addEventListener('click', function(e) { if (e.target === overlay) closeDialog(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDialog(); });

    var pending = localStorage.getItem('lp_pro_pending');
    if (pending) {
      localStorage.removeItem('lp_pro_pending');
      if (IS_PRO) {
        openDialog('success');
      } else {
        openDialog('activating');
        setTimeout(function() { window.location.reload(); }, 4500);
      }
    }
  })();

  // ── Scroll reveal ─────────────────────────────────────────────────────
  const revealObserver = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('active'); revealObserver.unobserve(e.target); } });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // ── Style preferences ──────────────────────────────────────────────────
  const PREFS_KEY = 'layered_style_prefs';
  const saved = JSON.parse(localStorage.getItem(PREFS_KEY) || '[]');

  document.querySelectorAll('.pf-pref-btn').forEach(btn => {
    if (saved.includes(btn.dataset.cat)) {
      btn.classList.add('active');
    }
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      // keep backward compat class names
      btn.classList.toggle('bg-white');
      btn.classList.toggle('text-black');
      btn.classList.toggle('border-white');
    });
  });

  document.getElementById('pf-save-prefs')?.addEventListener('click', () => {
    const active = [...document.querySelectorAll('.pf-pref-btn')]
      .filter(b => b.classList.contains('active'))
      .map(b => b.dataset.cat);
    localStorage.setItem(PREFS_KEY, JSON.stringify(active));
    const msg = document.getElementById('pf-prefs-saved');
    if (msg) { msg.classList.remove('hidden'); setTimeout(() => msg.classList.add('hidden'), 2000); }
  });

  // ── Saved outfit builds ───────────────────────────────────────────────
  const container = document.getElementById('pf-outfits-list');
  if (!container) return;

  try {
    const raw = localStorage.getItem('layered-outfit');
    const outfitState = raw ? JSON.parse(raw) : null;
    const slots = outfitState?.state?.slots || {};
    const filled = Object.entries(slots).filter(([, v]) => v && v.product);

    if (filled.length === 0) {
      container.innerHTML = '<p class="lp-body-muted">No saved blueprints found in the current session. <a href="/outfits/build" style="text-decoration:underline;color:inherit;opacity:0.7;transition:opacity 0.2s" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.7">Start a new build →</a></p>';
      return;
    }

    let html = '<div class="lp-outfit-grid">';
    filled.forEach(([slot, v]) => {
      const img   = v.product?.node?.images?.edges?.[0]?.node?.url || '';
      const title = v.product?.node?.title || slot;
      const label = slot.charAt(0).toUpperCase() + slot.slice(1);
      html += `<div class="lp-outfit-card">
        <div class="lp-outfit-card-image">
          ${img
            ? `<img src="${img}" alt="${title}">`
            : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:9px;text-transform:uppercase;letter-spacing:0.2em;color:rgba(14,14,14,0.25);font-weight:700">${label}</div>`
          }
        </div>
        <p class="lp-outfit-label">${label}</p>
        <p class="lp-outfit-title">${title}</p>
      </div>`;
    });
    html += '</div>';
    html += '<a href="/outfits/build" class="lp-reconfigure-btn">Reconfigure Build →</a>';
    container.innerHTML = html;
  } catch(e) {
    container.innerHTML = '<p class="lp-body-muted">Archive retrieval failed.</p>';
  }
})();
</script>
