{% comment %} Profile — uses SPA design tokens from layered-app.css {% endcomment %}

{%- comment -%} ── Minimal site nav for native pages ── {%- endcomment -%}
<header class="fixed top-0 inset-x-0 z-50 border-b border-white/5 bg-black/60 backdrop-blur-xl transition-colors duration-300">
  <div class="container max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="font-display text-2xl tracking-tighter text-white group flex items-center gap-2">
      <span class="w-8 h-8 bg-white text-black rounded-full flex items-center justify-center font-bold text-base transition-transform group-hover:rotate-12">L</span>
      Layered
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a href="/collections/all" class="text-[10px] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors">Shop</a>
      <a href="/outfits" class="text-[10px] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors">Outfits</a>
      <a href="/ai-assistant" class="text-[10px] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors">AI Stylist</a>
      <a href="/pages/profile" class="text-[10px] uppercase tracking-[0.2em] text-white border-b border-white pb-1">Profile</a>
      <a href="/pages/pricing" class="text-[10px] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors">Pricing</a>
      {% if customer %}
        <a href="/account" class="text-[10px] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="text-[10px] uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors">Sign in</a>
      {% endif %}
    </nav>
    <button id="pf-menu-toggle" class="md:hidden p-2 -mr-2 text-white" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8h18M3 16h18"/></svg>
    </button>
  </div>
  <div id="pf-mobile-menu" class="md:hidden hidden border-t border-white/5 bg-black/95 backdrop-blur-2xl">
    <div class="container max-w-7xl mx-auto px-6 py-8 flex flex-col gap-6">
      <a href="/collections/all" class="text-xl font-display text-white/70 hover:text-white">Shop</a>
      <a href="/outfits" class="text-xl font-display text-white/70 hover:text-white">Outfits</a>
      <a href="/ai-assistant" class="text-xl font-display text-white/70 hover:text-white">AI Stylist</a>
      <a href="/pages/profile" class="text-xl font-display text-white">Profile</a>
      <a href="/pages/pricing" class="text-xl font-display text-white/70 hover:text-white">Pricing</a>
      {% if customer %}
        <a href="/account" class="text-xl font-display text-white/70 hover:text-white">Account</a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="text-xl font-display text-white/70 hover:text-white">Sign in</a>
      {% endif %}
    </div>
  </div>
</header>

<div class="min-h-screen bg-black text-white pt-16">
  <div class="container max-w-7xl mx-auto px-6 py-20">

    {% if customer %}

      {%- comment -%} ── Page heading ── {%- endcomment -%}
      <div class="mb-20">
        <p class="text-[10px] tracking-[0.4em] uppercase text-white/40 mb-6 font-semibold">Dashboard</p>
        <h1 class="font-display text-6xl md:text-8xl leading-[0.9] tracking-tighter">{{ customer.first_name }}<span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white to-white/30 italic">'s space.</span></h1>
      </div>

      <div class="grid lg:grid-cols-3 gap-12">

        {%- comment -%} ── Left column ── {%- endcomment -%}
        <div class="lg:col-span-2 space-y-12">

          {%- comment -%} Usage tracker (AI Generations) {%- endcomment -%}
          {% if customer.tags contains 'Pro Member' %}
            <div class="bg-white/5 border border-white/10 p-8 md:p-10 relative overflow-hidden group">
              <div class="absolute inset-0 bg-gradient-to-br from-purple-500/5 via-transparent to-blue-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="relative z-10">
                <div class="flex items-center justify-between mb-8">
                  <div>
                    <h2 class="text-[10px] uppercase tracking-[0.2em] text-white/40 mb-1 font-bold">Pro Membership Perk</h2>
                    <p class="text-xl font-display">AI Virtual Try-On Generations</p>
                  </div>
                  <div class="text-right">
                    <span class="text-3xl font-display">42</span>
                    <span class="text-white/30 text-xs">/ 100</span>
                  </div>
                </div>
                <div class="h-1.5 w-full bg-white/5 rounded-full overflow-hidden mb-4">
                  <div class="h-full bg-gradient-to-r from-purple-500 to-blue-500 w-[42%] rounded-full shadow-[0_0_15px_rgba(168,85,247,0.4)]"></div>
                </div>
                <div class="flex justify-between text-[10px] uppercase tracking-widest text-white/30 font-bold">
                  <span>Usage this month</span>
                  <span>58 Remaining</span>
                </div>
              </div>
            </div>
          {% endif %}

          {%- comment -%} Account details card {%- endcomment -%}
          <div class="bg-white/5 border border-white/10 p-8 md:p-10">
            <div class="flex items-center justify-between mb-10">
              <h2 class="text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold">Account Intelligence</h2>
              <a href="/account" class="text-[10px] uppercase tracking-widest text-white/40 hover:text-white transition-colors border-b border-white/10 pb-0.5">Modify Account</a>
            </div>
            <div class="grid sm:grid-cols-2 gap-8">
              <div>
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/20 mb-2">Legal Identity</p>
                <p class="text-lg font-medium">{{ customer.name | default: '—' }}</p>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/20 mb-2">Digital Address</p>
                <p class="text-lg font-medium truncate">{{ customer.email }}</p>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/20 mb-2">Member Since</p>
                <p class="text-lg font-medium">{{ customer.created_at | date: "%B %Y" }}</p>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-[0.2em] text-white/20 mb-2">History</p>
                <p class="text-lg font-medium">{{ customer.orders.size }} Orders</p>
              </div>
            </div>
          </div>

          {%- comment -%} Style preferences {%- endcomment -%}
          <div class="bg-white/5 border border-white/10 p-8 md:p-10">
            <h2 class="text-[10px] uppercase tracking-[0.2em] text-white/40 mb-10 font-bold">Style Algorithm</h2>
            <p class="text-sm text-white/40 mb-8 leading-relaxed">Select your areas of focus. Our engine uses these to curate your feed.</p>
            <div id="pf-prefs" class="flex flex-wrap gap-3 mb-10">
              {%- assign categories = 'Tops,Bottoms,Outerwear,Shoes,Accessories' | split: ',' -%}
              {% for cat in categories %}
                <button
                  data-cat="{{ cat }}"
                  class="pf-pref-btn px-6 py-3 text-[10px] uppercase tracking-[0.2em] border border-white/10 transition-all hover:border-white font-bold"
                >{{ cat }}</button>
              {% endfor %}
            </div>
            <button id="pf-save-prefs" class="group relative px-8 py-4 bg-white text-black text-[10px] uppercase tracking-[0.2em] font-bold overflow-hidden transition-transform hover:scale-105 active:scale-95">
              Sync Preferences
            </button>
            <p id="pf-prefs-saved" class="text-[10px] uppercase tracking-widest text-green-500 mt-4 hidden font-bold">Preferences synchronized.</p>
          </div>

          {%- comment -%} Saved outfits {%- endcomment -%}
          <div class="bg-white/5 border border-white/10 p-8 md:p-10">
            <div class="flex items-center justify-between mb-10">
              <h2 class="text-[10px] uppercase tracking-[0.2em] text-white/40 font-bold">Saved Blueprints</h2>
              <a href="/outfits/build" class="text-[10px] uppercase tracking-widest text-white/40 hover:text-white transition-colors border-b border-white/10 pb-0.5">New Build →</a>
            </div>
            <div id="pf-outfits-list">
              <p class="text-sm text-white/20">Initialising archives…</p>
            </div>
          </div>

        </div>

        {%- comment -%} ── Right sidebar ── {%- endcomment -%}
        <div class="space-y-8">

          {%- comment -%} Identity card {%- endcomment -%}
          <div class="bg-white/5 border border-white/10 p-10 text-center relative overflow-hidden">
            <div class="w-20 h-20 bg-white text-black flex items-center justify-center text-3xl font-display mx-auto mb-6 rounded-full">
              {{ customer.first_name | slice: 0 | upcase }}
            </div>
            <p class="font-display text-2xl mb-1">{{ customer.name }}</p>
            <p class="text-[10px] text-white/30 uppercase tracking-[0.2em] mb-8">{{ customer.email }}</p>
            
            {% if customer.tags contains 'Pro Member' %}
              <div class="inline-flex items-center gap-2 px-4 py-2 bg-white text-black text-[10px] uppercase tracking-[0.2em] font-bold">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                Pro Member
              </div>
              <p class="text-[9px] text-white/20 mt-4 uppercase tracking-[0.2em]">15% Discount Active</p>
            {% else %}
              <a href="/pages/pricing" class="group relative inline-block w-full py-4 bg-transparent border border-white text-white text-[10px] uppercase tracking-[0.2em] font-bold overflow-hidden transition-all hover:bg-white hover:text-black">
                Upgrade to Pro
              </a>
              <p class="text-[9px] text-white/20 mt-4 uppercase tracking-[0.2em]">Unlock 15% discount</p>
            {% endif %}
          </div>

          {%- comment -%} Quick links {%- endcomment -%}
          <div class="bg-white/5 border border-white/10 p-10">
            <h3 class="text-[10px] uppercase tracking-[0.4em] text-white/40 mb-8 font-bold">Navigation</h3>
            <ul class="space-y-6 text-[10px] uppercase tracking-[0.2em] font-bold">
              <li><a href="/account" class="text-white/40 hover:text-white transition-colors flex items-center justify-between group">Order Archive <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span></a></li>
              <li><a href="{{ routes.account_addresses_url }}" class="text-white/40 hover:text-white transition-colors flex items-center justify-between group">Addresses <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span></a></li>
              <li><a href="/pages/pricing" class="text-white/40 hover:text-white transition-colors flex items-center justify-between group">Membership <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span></a></li>
              <li><a href="/collections/all" class="text-white/40 hover:text-white transition-colors flex items-center justify-between group">Marketplace <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span></a></li>
              <li class="pt-4 border-t border-white/5"><a href="{{ routes.account_logout_url }}" class="text-red-500/50 hover:text-red-500 transition-colors">Terminate Session</a></li>
            </ul>
          </div>

        </div>
      </div>

    {% else %}

      <div class="max-w-xl mx-auto text-center py-32 border border-dashed border-white/10 bg-white/5">
        <h2 class="font-display text-4xl mb-6">Authorisation Required</h2>
        <p class="text-sm text-white/40 mb-10 max-w-xs mx-auto leading-relaxed">Your profile and style algorithm are only accessible within an active session.</p>
        <a href="{{ routes.account_login_url }}?return_to=/pages/profile" class="inline-block bg-white text-black text-[10px] uppercase tracking-[0.4em] px-12 py-5 font-bold hover:scale-105 transition-transform">
          Sign In
        </a>
      </div>

    {% endif %}

  </div>
</div>

<style>
  /* ── Arbitrary Tailwind class fallbacks (not compiled into layered-app.css) ── */
  .text-\[10px\] { font-size: 10px; }
  .text-\[9px\]  { font-size: 9px; }
  .text-\[8px\]  { font-size: 8px; }
  .tracking-\[0\.2em\] { letter-spacing: .2em; }
  .tracking-\[0\.3em\] { letter-spacing: .3em; }
  .tracking-\[0\.4em\] { letter-spacing: .4em; }
  .leading-\[0\.9\]    { line-height: .9; }
  .w-\[42\%\]          { width: 42%; }
  .aspect-\[3\/4\]     { aspect-ratio: 3 / 4; }

  /* Opacity-modified backgrounds */
  .bg-white\/5   { background-color: rgb(255 255 255/.05); }
  .bg-white\/10  { background-color: rgb(255 255 255/.10); }
  .bg-white\/20  { background-color: rgb(255 255 255/.20); }
  .bg-black\/5   { background-color: rgb(0 0 0/.05); }
  .bg-black\/60  { background-color: rgb(0 0 0/.60); }
  .bg-black\/95  { background-color: rgb(0 0 0/.95); }

  /* Opacity-modified borders */
  .border-white\/5  { border-color: rgb(255 255 255/.05); }
  .border-white\/10 { border-color: rgb(255 255 255/.10); }
  .border-white\/20 { border-color: rgb(255 255 255/.20); }

  /* Opacity-modified text */
  .text-white\/10 { color: rgb(255 255 255/.10); }
  .text-white\/20 { color: rgb(255 255 255/.20); }
  .text-white\/30 { color: rgb(255 255 255/.30); }
  .text-white\/40 { color: rgb(255 255 255/.40); }
  .text-white\/50 { color: rgb(255 255 255/.50); }
  .text-white\/60 { color: rgb(255 255 255/.60); }
  .text-white\/70 { color: rgb(255 255 255/.70); }
  .text-white\/80 { color: rgb(255 255 255/.80); }
  .text-black\/30 { color: rgb(0 0 0/.30); }
  .text-black\/40 { color: rgb(0 0 0/.40); }
  .text-black\/60 { color: rgb(0 0 0/.60); }

  /* Progress bar gradient */
  .from-purple-500 { --tw-gradient-from: #a855f7; --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(168 85 247/0)); }
  .to-blue-500     { --tw-gradient-to: #3b82f6; }
  .to-white\/30    { --tw-gradient-to: rgb(255 255 255/.30); }

  /* Hover gradient overlay on AI card */
  .from-purple-500\/5 { --tw-gradient-from: rgb(168 85 247/.05); --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(168 85 247/0)); }
  .to-blue-500\/5     { --tw-gradient-to: rgb(59 130 246/.05); }

  /* Backdrop blur */
  .backdrop-blur-sm  { -webkit-backdrop-filter: blur(4px);  backdrop-filter: blur(4px); }
  .backdrop-blur-xl  { -webkit-backdrop-filter: blur(24px); backdrop-filter: blur(24px); }
  .backdrop-blur-2xl { -webkit-backdrop-filter: blur(40px); backdrop-filter: blur(40px); }

  /* Scale transitions */
  .hover\:scale-105:hover   { transform: scale(1.05); }
  .active\:scale-95:active  { transform: scale(.95); }

  /* Named-group (group/item) for saved outfit cards */
  .group\/item:hover .group-hover\/item\:scale-110 { transform: scale(1.10); }
</style>

<script>
(function() {
  // Mobile menu toggle
  const toggle = document.getElementById('pf-menu-toggle');
  const menu   = document.getElementById('pf-mobile-menu');
  if (toggle && menu) toggle.addEventListener('click', () => menu.classList.toggle('hidden'));

  // ── Style preferences ──────────────────────────────────────────────────
  const PREFS_KEY = 'layered_style_prefs';
  const saved = JSON.parse(localStorage.getItem(PREFS_KEY) || '[]');

  document.querySelectorAll('.pf-pref-btn').forEach(btn => {
    if (saved.includes(btn.dataset.cat)) {
      btn.classList.add('bg-white', 'text-black', 'border-white');
    }
    btn.addEventListener('click', () => {
      btn.classList.toggle('bg-white');
      btn.classList.toggle('text-black');
      btn.classList.toggle('border-white');
    });
  });

  document.getElementById('pf-save-prefs')?.addEventListener('click', () => {
    const active = [...document.querySelectorAll('.pf-pref-btn')]
      .filter(b => b.classList.contains('bg-white'))
      .map(b => b.dataset.cat);
    localStorage.setItem(PREFS_KEY, JSON.stringify(active));
    const msg = document.getElementById('pf-prefs-saved');
    if (msg) { msg.classList.remove('hidden'); setTimeout(() => msg.classList.add('hidden'), 2000); }
  });

  // ── Saved outfit builds ───────────────────────────────────────────────
  const container = document.getElementById('pf-outfits-list');
  if (!container) return;

  try {
    const raw = localStorage.getItem('layered-outfit');
    const outfitState = raw ? JSON.parse(raw) : null;
    const slots = outfitState?.state?.slots || {};
    const filled = Object.entries(slots).filter(([, v]) => v && v.product);

    if (filled.length === 0) {
      container.innerHTML = '<p class="text-sm text-white/20">No saved blueprints found in the current session. <a href="/outfits/build" class="underline hover:text-white transition-colors">Start a new build →</a></p>';
      return;
    }

    let html = '<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">';
    filled.forEach(([slot, v]) => {
      const img   = v.product?.node?.images?.edges?.[0]?.node?.url || '';
      const title = v.product?.node?.title || slot;
      const label = slot.charAt(0).toUpperCase() + slot.slice(1);
      html += `<div class="group/item">
        <div class="aspect-[3/4] bg-white/5 mb-3 overflow-hidden border border-white/5">
          ${img ? `<img src="${img}" alt="${title}" class="w-full h-full object-cover transition-transform group-hover/item:scale-110 duration-500">` : '<div class="w-full h-full flex items-center justify-center text-white/10 text-[10px] uppercase tracking-widest">' + label + '</div>'}
        </div>
        <p class="text-[8px] uppercase tracking-[0.2em] text-white/20 mb-1 font-bold">${label}</p>
        <p class="text-[10px] uppercase tracking-widest truncate font-medium">${title}</p>
      </div>`;
    });
    html += '</div>';
    html += '<a href="/outfits/build" class="inline-block mt-8 text-[10px] uppercase tracking-[0.2em] border border-white/10 px-6 py-3 hover:border-white transition-colors font-bold">Reconfigure Build →</a>';
    container.innerHTML = html;
  } catch(e) {
    container.innerHTML = '<p class="text-sm text-white/20">Archive retrieval failed.</p>';
  }
})();
</script>
