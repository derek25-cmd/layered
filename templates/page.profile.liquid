{%- comment -%} ── Hide Shopify default header/footer so only our navbar shows ── {%- endcomment -%}
<style>
  .shopify-section-group-header-group,
  .shopify-section-group-footer-group,
  .shopify-section--header,
  .shopify-section--footer { display: none !important; }
</style>

{%- comment -%} ── Google Fonts — Fraunces (display serif) + Inter (UI sans) ── {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  /* ── Layered Design System — Global Typography ── */
  *, *::before, *::after { box-sizing: border-box; }

  .font-display {
    font-family: 'Fraunces', serif;
    font-weight: 400;
  }

  /* Tailwind-compatible utility shims used in the markup */
  .text-2xl  { font-size: 1.5rem;   line-height: 2rem; }
  .text-4xl  { font-size: 2.25rem;  line-height: 2.5rem; }
  .text-lg   { font-size: 1.125rem; line-height: 1.75rem; }
  .tracking-tight { letter-spacing: -0.025em; }

  /* Tailwind flex/layout shims that may not be in the theme */
  .flex           { display: flex; }
  .items-center   { align-items: center; }
  .items-start    { align-items: flex-start; }
  .justify-between{ justify-content: space-between; }
  .justify-center { justify-content: center; }
  .gap-2  { gap: 0.5rem; }
  .gap-6  { gap: 1.5rem; }
  .gap-8  { gap: 2rem; }
  .gap-14 { gap: 3.5rem; }
  .gap-3  { gap: 0.75rem; }
  .gap-4  { gap: 1rem; }
  .gap-1  { gap: 0.25rem; }
  .flex-col     { flex-direction: column; }
  .flex-shrink-0{ flex-shrink: 0; }
  .flex-wrap    { flex-wrap: wrap; }
  .hidden       { display: none; }
  .w-full       { width: 100%; }
  .block        { display: block; }
  .inline-block { display: inline-block; }
  .inline-flex  { display: inline-flex; }
  .relative     { position: relative; }
  .absolute     { position: absolute; }
  .fixed        { position: fixed; }
  .inset-x-0    { left: 0; right: 0; }
  .inset-x-1    { left: 0.25rem; right: 0.25rem; }
  .inset-x-2    { left: 0.5rem; right: 0.5rem; }
  .top-0        { top: 0; }
  .z-50         { z-index: 50; }
  .py-5         { padding-top: 1.25rem; padding-bottom: 1.25rem; }
  .mx-auto      { margin-left: auto; margin-right: auto; }
  .px-6         { padding-left: 1.5rem; padding-right: 1.5rem; }
  .px-8         { padding-left: 2rem; padding-right: 2rem; }
  .py-6         { padding-top: 1.5rem; padding-bottom: 1.5rem; }
  .py-24        { padding-top: 6rem; padding-bottom: 6rem; }
  .pt-20        { padding-top: 5rem; }
  .max-w-7xl    { max-width: 80rem; }
  .container    { width: 100%; }
  .text-right   { text-align: right; }
  .text-center  { text-align: center; }
  .border-t     { border-top-width: 1px; border-top-style: solid; }
  .overflow-hidden { overflow: hidden; }
  .min-h-screen { min-height: 100vh; }
  .space-y-1 > * + * { margin-top: 0.25rem; }
  .space-y-8 > * + * { margin-top: 2rem; }
  .space-y-10 > * + * { margin-top: 2.5rem; }
  .mb-1  { margin-bottom: 0.25rem; }
  .mb-3  { margin-bottom: 0.75rem; }
  .mb-4  { margin-bottom: 1rem; }
  .mb-5  { margin-bottom: 1.25rem; }
  .mb-6  { margin-bottom: 1.5rem; }
  .mb-8  { margin-bottom: 2rem; }
  .mb-10 { margin-bottom: 2.5rem; }
  .mb-12 { margin-bottom: 3rem; }
  .mb-24 { margin-bottom: 6rem; }
  .mt-3  { margin-top: 0.75rem; }
  .mt-4  { margin-top: 1rem; }
  .mt-8  { margin-top: 2rem; }
  .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .w-7  { width: 1.75rem; }
  .h-7  { height: 1.75rem; }
  .h-\[6px\] { height: 6px; }
  .top-\[10px\] { top: 10px; }
  .top-\[20px\] { top: 20px; }

  /* Grid shims */
  .grid { display: grid; }
  .gap-10 { gap: 2.5rem; }
  .gap-12 { gap: 3rem; }

  @media (min-width: 768px) {
    .md\:flex   { display: flex; }
    .md\:hidden { display: none; }
  }
  @media (min-width: 640px) {
    .sm\:flex { display: flex; }
    .sm\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0,1fr)); }
  }
  @media (min-width: 1024px) {
    .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0,1fr)); }
    .lg\:col-span-2  { grid-column: span 2 / span 2; }
  }

  /* Hover translate shims */
  .transition-transform { transition-property: transform; transition-timing-function: cubic-bezier(.4,0,.2,1); transition-duration: 150ms; }
  .group:hover .group-hover\:-translate-y-0\.5 { transform: translateY(-2px); }
  .group:hover .group-hover\:translate-y-0\.5  { transform: translateY(2px); }
</style>

{%- comment -%} ── Navbar — mirrors Navbar.tsx layout & behaviour ── {%- endcomment -%}
<header id="lp-header" class="lp-nav fixed top-0 inset-x-0 z-50 py-5 transition-all duration-500">
  <div class="container max-w-7xl mx-auto px-6 flex items-center justify-between gap-6">

    {%- comment -%} Logo — 3-layer stacked bars matching Navbar.tsx {%- endcomment -%}
    <a href="/" class="flex items-center gap-2 group" aria-label="Layered home">
      <div class="lp-logo-layers relative w-7 h-7 flex-shrink-0">
        <div class="absolute inset-x-0 top-0     h-[6px] lp-bar lp-bar--top rounded-sm transition-transform group-hover:-translate-y-0.5"></div>
        <div class="absolute inset-x-1 top-[10px] h-[6px] lp-bar lp-bar--mid rounded-sm"></div>
        <div class="absolute inset-x-2 top-[20px] h-[6px] lp-bar lp-bar--bot rounded-sm transition-transform group-hover:translate-y-0.5"></div>
      </div>
      <span class="font-display text-2xl tracking-tight lp-logo-text">Layered</span>
    </a>

    {%- comment -%} Desktop nav links {%- endcomment -%}
    <nav class="hidden md:flex items-center gap-8">
      <a href="/collections/all" class="lp-nav-link">Shop</a>
      <a href="/outfit-builder" class="lp-nav-link">Create Outfit</a>
      <a href="/ai-assistant" class="lp-nav-link">AI Stylist</a>
      <a href="/pages/pricing" class="lp-nav-link">Pricing</a>
    </nav>

    {%- comment -%} Right rail — outfit icon + cart, mirroring Navbar.tsx right slot {%- endcomment -%}
    <div class="flex items-center gap-1">
      {% if customer %}
        <a href="/pages/profile" class="lp-icon-btn hidden sm:flex items-center relative" aria-label="Profile">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      {% endif %}
      <a href="/outfit-builder" class="lp-icon-btn hidden sm:flex items-center relative" aria-label="Outfit builder">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3a2 2 0 00-2 2v14a2 2 0 002 2h3m6 0h3a2 2 0 002-2V5a2 2 0 00-2-2H5"/><polyline points="9 3 9 8 12 11 15 8 15 3"/></svg>
      </a>
      <a href="/cart" class="lp-icon-btn flex items-center relative" aria-label="Shopping bag">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </a>
      <button id="pf-menu-toggle" class="lp-icon-btn md:hidden" aria-label="Menu" aria-expanded="false" aria-controls="pf-mobile-menu">
        <svg id="pf-icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="3" y1="6"  x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="pf-icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" class="hidden"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  {%- comment -%} Mobile menu — glass panel matching Navbar.tsx animate-fade-in {%- endcomment -%}
  <div id="pf-mobile-menu" class="md:hidden hidden lp-mobile-panel border-t lp-mobile-border">
    <nav class="container max-w-7xl mx-auto px-6 py-6 flex flex-col gap-4">
      <a href="/collections/all" class="text-lg font-display lp-mobile-link">Shop</a>
      <a href="/outfit-builder" class="text-lg font-display lp-mobile-link">Create Outfit</a>
      <a href="/ai-assistant" class="text-lg font-display lp-mobile-link">AI Stylist</a>
      <a href="/pages/pricing" class="text-lg font-display lp-mobile-link">Pricing</a>
      {% if customer %}
        <a href="/pages/profile" class="text-lg font-display lp-mobile-link">Profile</a>
      {% endif %}
    </nav>
  </div>
</header>

<div class="lp-page min-h-screen pt-20">
  <div class="container max-w-7xl mx-auto px-8 py-24">

    {% if customer %}

      {%- comment -%} ── Page heading ── {%- endcomment -%}
      <div class="lp-hero mb-24 reveal">
        <p class="lp-eyebrow mb-5">Dashboard</p>
        <h1 class="lp-display">{{ customer.first_name }}<span class="lp-display--italic">'s space.</span></h1>
        <div class="lp-hero-rule"></div>
      </div>

      <div class="grid lg:grid-cols-3 gap-14">

        {%- comment -%} ── Left column ── {%- endcomment -%}
        <div class="lg:col-span-2 space-y-10">

          {%- comment -%} Usage tracker {%- endcomment -%}
          {% if customer.tags contains 'Pro Member' %}
            <div class="lp-card reveal" id="pf-usage-card">
              <div class="lp-card-header">
                <div>
                  <p class="lp-label mb-1">Pro Membership Perk</p>
                  <p class="lp-card-title">AI Virtual Try-On Generations</p>
                </div>
                <div class="lp-usage-count text-right">
                  <span class="lp-stat-number" id="pf-stat-used">—</span>
                  <span class="lp-stat-denom" id="pf-stat-limit">/ —</span>
                </div>
              </div>
              <div class="lp-progress-track">
                <div class="lp-progress-fill" id="pf-progress-fill" style="width: 0%"></div>
              </div>
              <div class="lp-progress-labels">
                <span>Usage this month</span>
                <span id="pf-stat-remaining">Loading…</span>
              </div>
            </div>
          {% endif %}

          {%- comment -%} Account details card {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:80ms">
            <div class="lp-card-header mb-10">
              <p class="lp-label">Account Intelligence</p>
              <a href="/account" class="lp-text-link">Modify Account</a>
            </div>
            <div class="grid sm:grid-cols-2 gap-8">
              <div class="lp-field">
                <p class="lp-field-label">Legal Identity</p>
                <p class="lp-field-value">{{ customer.name | default: '—' }}</p>
              </div>
              <div class="lp-field">
                <p class="lp-field-label">Digital Address</p>
                <p class="lp-field-value truncate">{{ customer.email }}</p>
              </div>
              <div class="lp-field">
                <p class="lp-field-label">Member Since</p>
                <p class="lp-field-value">{{ customer.created_at | date: "%B %Y" }}</p>
              </div>
              <div class="lp-field">
                <p class="lp-field-label">History</p>
                <p class="lp-field-value">{{ customer.orders.size }} Orders</p>
              </div>
            </div>
          </div>

          {%- comment -%} Style preferences {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:160ms">
            <p class="lp-label mb-6">Style Algorithm</p>
            <p class="lp-body-muted mb-8">Select your areas of focus. Our engine uses these to curate your feed.</p>
            <div id="pf-prefs" class="flex flex-wrap gap-3 mb-10">
              {%- assign categories = 'Tops,Bottoms,Outerwear,Shoes,Accessories' | split: ',' -%}
              {% for cat in categories %}
                <button
                  data-cat="{{ cat }}"
                  class="pf-pref-btn lp-pref-btn"
                >{{ cat }}</button>
              {% endfor %}
            </div>
            <button id="pf-save-prefs" class="lp-btn-primary">
              Sync Preferences
            </button>
            <p id="pf-prefs-saved" class="lp-saved-msg mt-4 hidden">Preferences synchronized.</p>
          </div>

          {%- comment -%} Saved outfits {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:240ms">
            <div class="lp-card-header mb-10">
              <p class="lp-label">Saved Blueprints</p>
              <a href="/outfits/build" class="lp-text-link">New Build →</a>
            </div>
            <div id="pf-outfits-list">
              <p class="lp-body-muted">Initialising archives…</p>
            </div>
          </div>

        </div>

        {%- comment -%} ── Right sidebar ── {%- endcomment -%}
        <div class="space-y-8">

          {%- comment -%} Identity card {%- endcomment -%}
          <div class="lp-card lp-card--identity text-center reveal" style="transition-delay:120ms">
            <div class="lp-avatar mx-auto mb-6">
              {{ customer.first_name | slice: 0 | upcase }}
            </div>
            <p class="font-display text-2xl mb-1 lp-identity-name">{{ customer.name }}</p>
            <p class="lp-identity-email mb-8">{{ customer.email }}</p>
            
            {% if customer.tags contains 'Pro Member' %}
              <div class="lp-badge-pro inline-flex items-center gap-2 mb-3">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                Pro Member
              </div>
              <p class="lp-discount-note">15% Discount Active</p>
              <a href="mailto:{{ shop.email }}?subject=Cancel+Layered+Pro+Membership&body=Hi%2C+I+would+like+to+cancel+my+Layered+Pro+membership.+My+account+email+is+{{ customer.email | url_encode }}." class="lp-cancel-link">Cancel Membership</a>
            {% else %}
              <a href="/pages/pricing" class="lp-btn-outline w-full block">
                Upgrade to Pro
              </a>
              <p class="lp-discount-note mt-3">Unlock 15% discount</p>
            {% endif %}
          </div>

          {%- comment -%} Quick links {%- endcomment -%}
          <div class="lp-card reveal" style="transition-delay:200ms">
            <p class="lp-label mb-8">Navigation</p>
            <ul class="lp-nav-list space-y-1">
              <li><a href="/account" class="lp-nav-item group">Order Archive <span class="lp-nav-arrow">→</span></a></li>
              <li><a href="{{ routes.account_addresses_url }}" class="lp-nav-item group">Addresses <span class="lp-nav-arrow">→</span></a></li>
              <li><a href="/pages/pricing" class="lp-nav-item group">Membership <span class="lp-nav-arrow">→</span></a></li>
              <li><a href="/collections/all" class="lp-nav-item group">Marketplace <span class="lp-nav-arrow">→</span></a></li>
              <li class="lp-nav-divider"><a href="{{ routes.account_logout_url }}" class="lp-nav-item lp-nav-item--danger">Terminate Session</a></li>
            </ul>
          </div>

        </div>
      </div>

    {% else %}

      <div class="lp-auth-gate reveal">
        <div class="lp-auth-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h2 class="font-display text-4xl mb-5 lp-auth-title">Authorisation Required</h2>
        <p class="lp-auth-body mb-12">Your profile and style algorithm are only accessible within an active session.</p>
        <a href="{{ routes.account_login_url }}?return_to=/pages/profile" class="lp-btn-primary lp-btn-primary--large">
          Sign In
        </a>
      </div>

    {% endif %}

  </div>
</div>

{%- comment -%} ── Pro Activation Dialog ── {%- endcomment -%}
<div id="lp-pro-dialog" class="lp-dialog-overlay" role="dialog" aria-modal="true" aria-labelledby="lp-dialog-title">
  <div class="lp-dialog">
    <button class="lp-dialog-close" id="lp-dialog-close" aria-label="Close">✕</button>

    <div id="lp-dialog-success">
      <div class="lp-dialog-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" fill="#0E0E0E" opacity="0.55"/></svg>
      </div>
      <p class="lp-eyebrow mb-3">Membership Activated</p>
      <h2 id="lp-dialog-title" class="lp-dialog-heading">Welcome to Layered Pro<span class="lp-dialog-heading--italic">.</span></h2>
      <div class="lp-dialog-rule"></div>
      <ul class="lp-dialog-perks">
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>15% off every order, applied automatically</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>100 AI Virtual Try-On generations per month</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>Free shipping on every order</li>
        <li class="lp-dialog-perk"><span class="lp-dialog-perk-dot"></span>24-hour early access to new drops</li>
      </ul>
      <a href="/collections/all" class="lp-btn-primary lp-btn-primary--large lp-dialog-cta">Shop with Pro</a>
    </div>

    <div id="lp-dialog-activating" style="display:none">
      <div class="lp-dialog-icon lp-dialog-icon--pulse">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      </div>
      <p class="lp-eyebrow mb-3">One moment</p>
      <h2 class="lp-dialog-heading">Activating your membership<span class="lp-dialog-heading--italic">.</span></h2>
      <div class="lp-dialog-rule"></div>
      <p class="lp-body-muted" style="font-size:0.9rem">Your Pro membership is being confirmed. This page will refresh automatically in a few seconds.</p>
    </div>
  </div>
</div>

<style>
  /* ── Layered Profile — Redesign ──────────────────────────────────────────── */
  :root {
    --beige: #F2EBE3;
    --beige-dark: #E8DDD3;
    --beige-mid: #D4C9BE;
    --black: #0E0E0E;
    --off-black: #1A1A1A;
    --soft-black: #2C2C2C;
    --white: #FFFFFF;
    --cream: #FAF8F5;
  }

  /* ── Base page ──────────────────────────────────────────────────────────── */
  .lp-page {
    background-color: var(--cream);
    color: var(--black);
    font-family: 'Inter', system-ui, sans-serif;
    min-height: 100vh;
  }

    /* ══ Navbar — mirrors Navbar.tsx ═════════════════════════════════════════ */

  /* Base — transparent + py-5 (matches `py-5 bg-transparent` in Navbar.tsx) */
  .lp-nav {
    transition: background 0.5s ease, padding-top 0.5s ease, padding-bottom 0.5s ease, box-shadow 0.3s ease;
  }

  /* Scrolled — glass + py-3 (matches `glass py-3` className in Navbar.tsx)  */
  .lp-nav.lp-nav--scrolled {
    background: rgba(250, 248, 245, 0.88) !important;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(14,14,14,0.07);
    padding-top: 0.75rem !important;
    padding-bottom: 0.75rem !important;
  }

  /* 3-layer stacked logo bars — foreground / secondary / muted             */
  .lp-bar { background: var(--black); }
  .lp-bar--top { opacity: 1.0; }
  .lp-bar--mid { opacity: 0.45; }
  .lp-bar--bot { opacity: 0.2; }

  .lp-logo-text {
    color: var(--black);
    letter-spacing: -0.04em;
  }

  /* Desktop nav links — text-sm uppercase underline pattern from Navbar.tsx */
  .lp-nav-link {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    color: rgba(14,14,14,0.55);
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
    transition: color 0.2s ease;
  }

  .lp-nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    height: 1px;
    background: var(--black);
    width: 0;
    transition: width 0.25s ease;
  }

  .lp-nav-link:hover              { color: var(--black); }
  .lp-nav-link:hover::after       { width: 100%; }
  .lp-nav-link--active            { color: var(--black); }
  .lp-nav-link--active::after     { width: 100%; }

  /* Icon buttons — right rail (matches Navbar.tsx hover:bg-foreground/5 rounded-full) */
  .lp-icon-btn {
    padding: 8px;
    color: var(--black);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 9999px;
    transition: background 0.2s ease;
    text-decoration: none;
  }
  .lp-icon-btn:hover { background: rgba(14,14,14,0.06); }

  /* Mobile panel — glass + animate-fade-in (matches Navbar.tsx mobile open) */
  .lp-mobile-panel {
    background: rgba(250,248,245,0.96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    animation: lp-fade-in 0.18s ease forwards;
  }
  .lp-mobile-border { border-color: rgba(14,14,14,0.08); }

  /* Mobile links — font-display italic (matches Navbar.tsx `text-lg font-display`) */
  .lp-mobile-link {
    font-style: italic;
    color: rgba(14,14,14,0.55);
    text-decoration: none;
